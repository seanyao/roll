#!/usr/bin/env bash
set -euo pipefail

# Cybernetix — AI Agent Convention Manager
# Single source of truth for how all AI coding agents behave.

VERSION="0.2.0"
CNX_HOME="${HOME}/.cybernetix"
CNX_CONFIG="${CNX_HOME}/config.yaml"
CNX_GLOBAL="${CNX_HOME}/conventions/global"
CNX_TEMPLATES="${CNX_HOME}/conventions/templates"

# Find repo root (resolve symlinks so it works from ~/.local/bin/cybernetix)
_source="${BASH_SOURCE[0]}"
while [[ -L "$_source" ]]; do
  _dir="$(cd "$(dirname "$_source")" && pwd)"
  _source="$(readlink "$_source")"
  [[ "$_source" != /* ]] && _source="$_dir/$_source"
done
SCRIPT_DIR="$(cd "$(dirname "$_source")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
REPO_CONVENTIONS="${REPO_ROOT}/conventions"

# Colors
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
NC=$'\033[0m'

# Respect NO_COLOR
if [[ -n "${NO_COLOR:-}" ]]; then
  RED='' GREEN='' YELLOW='' CYAN='' BOLD='' NC=''
fi

info()  { echo -e "${CYAN}[cnx]${NC} $*"; }
ok()    { echo -e "${GREEN}[cnx]${NC} $*"; }
warn()  { echo -e "${YELLOW}[cnx]${NC} $*"; }
err()   { echo -e "${RED}[cnx]${NC} $*" >&2; }

# ─── Helper: read config value ───────────────────────────────────────────────
# Simple YAML reader — no dependencies. Handles flat key: value pairs.
config_get() {
  local key="$1"
  local default="${2:-}"
  if [[ -f "$CNX_CONFIG" ]]; then
    local val
    val=$(grep -E "^${key}:" "$CNX_CONFIG" 2>/dev/null | head -1 | sed 's/^[^:]*:[[:space:]]*//' | sed 's/[[:space:]]*$//')
    if [[ -n "$val" ]]; then
      # Expand ~ to $HOME
      echo "${val/#\~/$HOME}"
      return
    fi
  fi
  echo "${default/#\~/$HOME}"
}

# ─── Helper: safe copy with overwrite prompt ─────────────────────────────────
safe_copy() {
  local src="$1"
  local dst="$2"
  local force="${3:-false}"

  if [[ ! -f "$src" ]]; then
    return
  fi

  local dst_dir
  dst_dir="$(dirname "$dst")"
  mkdir -p "$dst_dir"

  if [[ -f "$dst" ]] && [[ "$force" != "true" ]]; then
    # Check if content is identical
    if diff -q "$src" "$dst" &>/dev/null; then
      return  # identical, skip silently
    fi
    echo ""
    warn "File exists and differs: ${dst/#$HOME/~}"
    echo -e "  ${BOLD}Overwrite?${NC} [y/N/d(iff)] "
    read -r answer
    case "$answer" in
      d|D|diff)
        diff --color=auto "$dst" "$src" || true
        echo ""
        echo -e "  ${BOLD}Overwrite?${NC} [y/N] "
        read -r answer2
        [[ "$answer2" =~ ^[Yy]$ ]] || { info "Skipped: ${dst/#$HOME/\~}"; return; }
        ;;
      y|Y) ;;
      *) info "Skipped: ${dst/#$HOME/~}"; return ;;
    esac
  fi

  cp "$src" "$dst"
  ok "Wrote: ${dst/#$HOME/~}"
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: setup
# Initialize ~/.cybernetix/ on a new machine
# ═══════════════════════════════════════════════════════════════════════════════
cmd_setup() {
  info "Setting up Cybernetix on this machine..."
  echo ""

  # Verify repo source exists
  if [[ ! -d "$REPO_CONVENTIONS" ]]; then
    err "Convention source not found at: $REPO_CONVENTIONS"
    err "Run this from the cybernetix repo, or symlink bin/cybernetix to PATH."
    exit 1
  fi

  # Create directory structure
  mkdir -p "$CNX_GLOBAL"
  mkdir -p "$CNX_TEMPLATES"/{fullstack,frontend-only,backend-service,cli}

  # Copy global conventions
  info "Copying global conventions..."
  for f in "$REPO_CONVENTIONS"/global/*; do
    [[ -f "$f" ]] && safe_copy "$f" "$CNX_GLOBAL/$(basename "$f")"
  done
  # Handle dotfiles (not matched by *)
  for f in "$REPO_CONVENTIONS"/global/.*; do
    [[ -f "$f" ]] && [[ "$(basename "$f")" != "." ]] && [[ "$(basename "$f")" != ".." ]] && \
      safe_copy "$f" "$CNX_GLOBAL/$(basename "$f")"
  done

  # Copy project templates
  info "Copying project templates..."
  for tpl_dir in "$REPO_CONVENTIONS"/templates/*/; do
    local tpl_name
    tpl_name="$(basename "$tpl_dir")"
    for f in "$tpl_dir"*; do
      [[ -f "$f" ]] && safe_copy "$f" "$CNX_TEMPLATES/$tpl_name/$(basename "$f")"
    done
    for f in "$tpl_dir".*; do
      [[ -f "$f" ]] && [[ "$(basename "$f")" != "." ]] && [[ "$(basename "$f")" != ".." ]] && \
        safe_copy "$f" "$CNX_TEMPLATES/$tpl_name/$(basename "$f")"
    done
  done

  # Copy skills
  info "Installing skills..."
  mkdir -p "$CNX_HOME/skills"
  for skill_dir in "$REPO_ROOT"/skills/*/; do
    if [[ -d "$skill_dir" ]]; then
      local skill_name
      skill_name="$(basename "$skill_dir")"
      mkdir -p "$CNX_HOME/skills/$skill_name"
      for f in "$skill_dir"*; do
        [[ -f "$f" ]] && safe_copy "$f" "$CNX_HOME/skills/$skill_name/$(basename "$f")"
      done
    fi
  done

  # Create symlinks for AI tools
  info "Creating skill symlinks for AI tools..."
  local ai_dirs=(~/.claude ~/.gemini ~/.kimi ~/.codex ~/.cursor)
  for ai_dir in "${ai_dirs[@]}"; do
    ai_dir=$(eval echo "$ai_dir") # expand ~
    if [[ -d "$ai_dir" ]]; then
      local target_link="$ai_dir/skills"
      if [[ ! -e "$target_link" ]]; then
        ln -s "$CNX_HOME/skills" "$target_link"
        ok "Linked skills to ${target_link/#$HOME/~}"
      elif [[ -L "$target_link" ]]; then
        local current_target
        current_target="$(readlink "$target_link")"
        if [[ "$current_target" != "$CNX_HOME/skills" ]]; then
          warn "Symlink ${target_link/#$HOME/~} exists but points to $current_target"
          echo -n "  Overwrite symlink? [y/N] "
          read -r answer
          if [[ "$answer" =~ ^[Yy]$ ]]; then
            rm "$target_link"
            ln -s "$CNX_HOME/skills" "$target_link"
            ok "Updated link: ${target_link/#$HOME/~}"
          fi
        else
          ok "Link exists: ${target_link/#$HOME/~}"
        fi
      else
        warn "Directory or file exists at ${target_link/#$HOME/~}, skipping symlink"
      fi
    fi
  done

  # Create config if it doesn't exist
  if [[ ! -f "$CNX_CONFIG" ]]; then
    info "Creating default config..."
    cat > "$CNX_CONFIG" << 'YAML'
# Cybernetix Configuration
# Edit this file, then run `cybernetix sync` to apply.

# Sync targets: where global conventions are distributed to
sync_claude: ~/.claude/CLAUDE.md
sync_kimi: ~/.kimi/AGENTS.md
sync_codex: ~/.codex/AGENTS.md
sync_gemini: ~/.gemini/GEMINI.md

# User preferences
default_language: zh
default_project_type: fullstack
editor: ${EDITOR:-vim}
YAML
    ok "Created: ~/.cybernetix/config.yaml"
  fi

  # Install global git hook
  info "Installing global git hook..."
  local hooks_dir="$HOME/.config/git/hooks"
  local hook_src="$REPO_ROOT/hooks/prepare-commit-msg"
  local hook_dst="$hooks_dir/prepare-commit-msg"
  if [[ -f "$hook_src" ]]; then
    mkdir -p "$hooks_dir"
    safe_copy "$hook_src" "$hook_dst"
    chmod +x "$hook_dst"
    git config --global core.hooksPath "$hooks_dir"
    ok "Global git hook installed: AI client auto-detected on every commit"
  else
    warn "Hook source not found: $hook_src"
  fi

  echo ""
  ok "Setup complete. Directory: ~/.cybernetix/"
  echo ""
  info "Next steps:"
  echo "  1. Edit global conventions:  ${BOLD}cybernetix update${NC}"
  echo "  2. Sync to AI tools:         ${BOLD}cybernetix sync${NC}"
  echo "  3. Init a new project:       ${BOLD}cybernetix init${NC}"
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: sync
# Distribute global conventions and skills to each AI tool's config path
# ═══════════════════════════════════════════════════════════════════════════════
cmd_sync() {
  if [[ ! -d "$CNX_GLOBAL" ]]; then
    err "No global conventions found. Run 'cybernetix setup' first."
    exit 1
  fi

  info "Syncing global conventions and skills..."
  echo ""

  # 1. Update skills first
  cmd_update_skills

  local force="${1:-false}"

  # 2. Sync convention files
  # Claude Code: CLAUDE.md → ~/.claude/CLAUDE.md
  local claude_target
  claude_target="$(config_get sync_claude ~/.claude/CLAUDE.md)"
  if [[ -f "$CNX_GLOBAL/CLAUDE.md" ]]; then
    safe_copy "$CNX_GLOBAL/CLAUDE.md" "$claude_target" "$force"
  fi

  # Kimi Code: AGENTS.md → ~/.kimi/AGENTS.md
  local kimi_target
  kimi_target="$(config_get sync_kimi ~/.kimi/AGENTS.md)"
  if [[ -f "$CNX_GLOBAL/AGENTS.md" ]]; then
    safe_copy "$CNX_GLOBAL/AGENTS.md" "$kimi_target" "$force"
  fi

  # OpenAI Codex: AGENTS.md → ~/.codex/AGENTS.md
  local codex_target
  codex_target="$(config_get sync_codex ~/.codex/AGENTS.md)"
  if [[ -f "$CNX_GLOBAL/AGENTS.md" ]]; then
    safe_copy "$CNX_GLOBAL/AGENTS.md" "$codex_target" "$force"
  fi

  # Gemini CLI: GEMINI.md → ~/.gemini/GEMINI.md
  local gemini_target
  gemini_target="$(config_get sync_gemini ~/.gemini/GEMINI.md)"
  if [[ -f "$CNX_GLOBAL/GEMINI.md" ]]; then
    safe_copy "$CNX_GLOBAL/GEMINI.md" "$gemini_target" "$force"
  fi

  echo ""
  ok "Sync complete."
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: update
# Open global conventions for editing, then sync
# ═══════════════════════════════════════════════════════════════════════════════
cmd_update() {
  if [[ ! -d "$CNX_GLOBAL" ]]; then
    err "No global conventions found. Run 'cybernetix setup' first."
    exit 1
  fi

  local editor
  editor="$(config_get editor "${EDITOR:-vim}")"
  # Expand $EDITOR in the config value
  editor=$(eval echo "$editor")

  info "Opening global conventions in $editor..."
  info "Directory: ~/.cybernetix/conventions/global/"
  echo ""

  # Open the directory or specific file based on editor
  if command -v "$editor" &>/dev/null; then
    "$editor" "$CNX_GLOBAL"
  else
    err "Editor not found: $editor"
    err "Set your editor: export EDITOR=code (or vim, nano, etc.)"
    exit 1
  fi

  echo ""
  info "Editor closed. Running sync..."
  cmd_sync
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: init
# Initialize a project with convention files from a template
# ═══════════════════════════════════════════════════════════════════════════════
cmd_init() {
  if [[ ! -d "$CNX_TEMPLATES" ]]; then
    err "No templates found. Run 'cybernetix setup' first."
    exit 1
  fi

  local project_dir="${1:-.}"
  local project_type="${2:-}"
  local tools_arg="${3:-}"

  # Interactive project type selection if not provided
  if [[ -z "$project_type" ]]; then
    echo ""
    echo -e "${BOLD}Select project type:${NC}"
    echo ""
    echo "  1) fullstack        React + API + CLI (default)"
    echo "  2) frontend-only    React SPA, no backend"
    echo "  3) backend-service   API/microservice, no frontend"
    echo "  4) cli              Command-line tool"
    echo ""
    echo -n "Choice [1-4]: "
    read -r choice
    case "$choice" in
      1|"") project_type="fullstack" ;;
      2)    project_type="frontend-only" ;;
      3)    project_type="backend-service" ;;
      4)    project_type="cli" ;;
      *)    err "Invalid choice: $choice"; exit 1 ;;
    esac
  fi

  # AI tool selection — only generate files for tools you actually use
  local use_claude=false use_gemini=false use_cursor=false

  if [[ -n "$tools_arg" ]]; then
    # Parse comma-separated tool list: --tools=claude,gemini
    IFS=',' read -ra tool_list <<< "$tools_arg"
    for t in "${tool_list[@]}"; do
      case "$t" in
        claude) use_claude=true ;;
        gemini) use_gemini=true ;;
        cursor) use_cursor=true ;;
        all)    use_claude=true; use_gemini=true; use_cursor=true ;;
        *) warn "Unknown tool: $t" ;;
      esac
    done
  else
    echo ""
    echo -e "${BOLD}Which AI tools do you use?${NC} (space-separated, or 'a' for all)"
    echo ""
    echo "  c) Claude Code"
    echo "  g) Gemini CLI"
    echo "  r) Cursor IDE"
    echo "  a) All of the above"
    echo ""
    echo -n "Choice [c/g/r/a] (default: c): "
    read -r tool_choice
    tool_choice="${tool_choice:-c}"
    for ch in $tool_choice; do
      case "$ch" in
        c) use_claude=true ;;
        g) use_gemini=true ;;
        r) use_cursor=true ;;
        a) use_claude=true; use_gemini=true; use_cursor=true ;;
      esac
    done
  fi

  local tpl_dir="$CNX_TEMPLATES/$project_type"
  if [[ ! -d "$tpl_dir" ]]; then
    err "Template not found: $project_type"
    err "Available: fullstack, frontend-only, backend-service, cli"
    exit 1
  fi

  # Resolve project directory
  if [[ "$project_dir" != "." ]]; then
    mkdir -p "$project_dir"
  fi
  project_dir="$(cd "$project_dir" && pwd)"

  info "Initializing ${BOLD}$project_type${NC} conventions in: $project_dir"
  echo ""

  # AGENTS.md → project root (master conventions, tool-agnostic)
  merge_convention "AGENTS.md" "$tpl_dir" "$project_dir" "AGENTS.md"

  # Tool-specific files go into each tool's hidden directory
  local created_files="AGENTS.md"
  if [[ "$use_claude" == "true" ]]; then
    mkdir -p "$project_dir/.claude"
    merge_convention "CLAUDE.md" "$tpl_dir" "$project_dir/.claude" ".claude/CLAUDE.md"
    created_files+=", .claude/CLAUDE.md"
  fi
  if [[ "$use_gemini" == "true" ]]; then
    merge_convention "GEMINI.md" "$tpl_dir" "$project_dir" "GEMINI.md"
    created_files+=", GEMINI.md"
  fi
  if [[ "$use_cursor" == "true" ]]; then
    merge_convention ".cursor-rules" "$tpl_dir" "$project_dir" ".cursor-rules"
    created_files+=", .cursor-rules"
  fi

  echo ""
  ok "Convention files created for ${BOLD}$project_type${NC} project."
  echo ""
  info "Created: $created_files"
  echo ""
  info "Tip: use ${BOLD}\$cnx-init${NC} to scaffold the full project structure."
}

# ─── Helper: merge global preamble + template into output ────────────────────
# Args: source_filename tpl_dir out_dir display_name
merge_convention() {
  local filename="$1"
  local tpl_dir="$2"
  local out_dir="$3"
  local display="${4:-$filename}"
  local global_file="$CNX_GLOBAL/$filename"
  local tpl_file="$tpl_dir/$filename"
  local out_file="$out_dir/$filename"

  if [[ ! -f "$tpl_file" ]]; then
    return
  fi

  # Build merged file: global content + separator + template content
  local merged
  merged="$(cat "$global_file" 2>/dev/null || true)"
  merged+=$'\n\n'
  merged+="---"
  merged+=$'\n\n'
  merged+="$(cat "$tpl_file")"

  if [[ -f "$out_file" ]]; then
    if diff -q <(echo "$merged") "$out_file" &>/dev/null; then
      return  # identical
    fi
    warn "File exists: $display"
    echo -n "  Overwrite? [y/N] "
    read -r answer
    [[ "$answer" =~ ^[Yy]$ ]] || { info "Skipped: $display"; return; }
  fi

  echo "$merged" > "$out_file"
  ok "Created: $display"
}

# ─── Helper: detect project type from existing AGENTS.md ─────────────────────
detect_project_type() {
  local agents_file="$1/AGENTS.md"
  [[ -f "$agents_file" ]] || { echo "unknown"; return; }

  local content
  content="$(cat "$agents_file")"

  if echo "$content" | grep -qi "Fullstack Web"; then
    echo "fullstack"
  elif echo "$content" | grep -qi "Backend Service"; then
    echo "backend-service"
  elif echo "$content" | grep -qi "Frontend Only"; then
    echo "frontend-only"
  elif echo "$content" | grep -qi "CLI Tool"; then
    echo "cli"
  else
    echo "unknown"
  fi
}

# ─── Helper: detect AI tools from existing convention files ──────────────────
detect_tools() {
  local dir="$1"
  local tools=""
  [[ -f "$dir/.claude/CLAUDE.md" ]] && tools+="claude,"
  [[ -f "$dir/GEMINI.md" ]] && tools+="gemini,"
  [[ -f "$dir/.cursor-rules" ]] && tools+="cursor,"
  echo "${tools%,}"
}

# ─── Helper: refresh a single project ────────────────────────────────────────
refresh_project() {
  local project_dir="$1"
  local project_name
  project_name="$(basename "$project_dir")"

  local ptype
  ptype="$(detect_project_type "$project_dir")"

  if [[ "$ptype" == "unknown" ]]; then
    warn "  ${BOLD}$project_name${NC}: cannot detect project type — skipping"
    return 1
  fi

  local tools
  tools="$(detect_tools "$project_dir")"

  local tpl_dir="$CNX_TEMPLATES/$ptype"
  if [[ ! -d "$tpl_dir" ]]; then
    warn "  ${BOLD}$project_name${NC}: template '$ptype' not found — skipping"
    return 1
  fi

  info "  ${BOLD}$project_name${NC} ($ptype | ${tools:-AGENTS.md only})"

  merge_convention "AGENTS.md" "$tpl_dir" "$project_dir" "  AGENTS.md"

  if echo "$tools" | grep -q "claude"; then
    mkdir -p "$project_dir/.claude"
    merge_convention "CLAUDE.md" "$tpl_dir" "$project_dir/.claude" "  .claude/CLAUDE.md"
  fi
  if echo "$tools" | grep -q "gemini"; then
    merge_convention "GEMINI.md" "$tpl_dir" "$project_dir" "  GEMINI.md"
  fi
  if echo "$tools" | grep -q "cursor"; then
    merge_convention ".cursor-rules" "$tpl_dir" "$project_dir" "  .cursor-rules"
  fi

  return 0
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: refresh
# Auto-detect project type & tools, re-merge with latest templates
# Single project: cybernetix refresh .
# Batch: cybernetix refresh ~/CodeSpace/
# ═══════════════════════════════════════════════════════════════════════════════
cmd_refresh() {
  local target="${1:-.}"
  target="$(cd "$target" 2>/dev/null && pwd)" || { err "Directory not found: $1"; exit 1; }

  if [[ ! -d "$CNX_GLOBAL" ]]; then
    err "~/.cybernetix/ not set up. Run: cybernetix setup"
    exit 1
  fi

  # Single project mode: target dir itself has AGENTS.md
  if [[ -f "$target/AGENTS.md" ]]; then
    info "Refreshing single project..."
    echo ""
    refresh_project "$target"
    echo ""
    ok "Done."
    return
  fi

  # Batch mode: scan subdirectories for CNX projects
  info "Scanning ${BOLD}$target${NC} for CNX projects..."
  echo ""

  local found=0 updated=0 skipped=0

  while IFS= read -r agents_file; do
    local project_dir
    project_dir="$(dirname "$agents_file")"

    # Skip cybernetix repo itself and template directories
    case "$project_dir" in
      */.cybernetix/*|*/conventions/*|*/template*) continue ;;
    esac

    found=$((found + 1))
    if refresh_project "$project_dir"; then
      updated=$((updated + 1))
    else
      skipped=$((skipped + 1))
    fi
    echo ""
  done < <(find "$target" -maxdepth 2 -name "AGENTS.md" -type f 2>/dev/null | sort)

  if [[ $found -eq 0 ]]; then
    warn "No CNX projects found in $target"
    info "Looking for directories with AGENTS.md (depth <= 2)"
    return
  fi

  ok "Done: ${BOLD}$found${NC} projects found, ${BOLD}$updated${NC} refreshed, ${BOLD}$skipped${NC} skipped."
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: update-skills
# Refresh skills in ~/.cybernetix/skills from repo source
# ═══════════════════════════════════════════════════════════════════════════════
cmd_update_skills() {
  if [[ ! -d "$REPO_ROOT/skills" ]]; then
    err "Skills source not found at: $REPO_ROOT/skills"
    exit 1
  fi

  info "Updating skills in ~/.cybernetix/skills..."
  mkdir -p "$CNX_HOME/skills"
  
  # Copy subdirectories
  for skill_dir in "$REPO_ROOT"/skills/*/; do
    if [[ -d "$skill_dir" ]]; then
      local skill_name
      skill_name="$(basename "$skill_dir")"
      mkdir -p "$CNX_HOME/skills/$skill_name"
      for f in "$skill_dir"*; do
        [[ -f "$f" ]] && cp "$f" "$CNX_HOME/skills/$skill_name/$(basename "$f")"
      done
    fi
  done
  
  ok "Skills updated successfully."
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: reset
# Re-copy conventions and skills from repo source, then sync
# ═══════════════════════════════════════════════════════════════════════════════
cmd_reset() {
  if [[ ! -d "$REPO_CONVENTIONS" ]]; then
    err "Convention source not found at: $REPO_CONVENTIONS"
    err "Is the cybernetix repo still at $(dirname "$REPO_CONVENTIONS")?"
    exit 1
  fi

  warn "This will overwrite ~/.cybernetix/conventions/ and skills with repo defaults."
  echo -n "  Continue? [y/N] "
  read -r answer
  [[ "$answer" =~ ^[Yy]$ ]] || { info "Aborted."; return; }

  echo ""
  info "Resetting global conventions..."
  for f in "$REPO_CONVENTIONS"/global/*; do
    [[ -f "$f" ]] && safe_copy "$f" "$CNX_GLOBAL/$(basename "$f")" true
  done
  for f in "$REPO_CONVENTIONS"/global/.*; do
    [[ -f "$f" ]] && [[ "$(basename "$f")" != "." ]] && [[ "$(basename "$f")" != ".." ]] && \
      safe_copy "$f" "$CNX_GLOBAL/$(basename "$f")" true
  done

  info "Resetting templates..."
  for tpl_dir in "$REPO_CONVENTIONS"/templates/*/; do
    local tpl_name
    tpl_name="$(basename "$tpl_dir")"
    mkdir -p "$CNX_TEMPLATES/$tpl_name"
    for f in "$tpl_dir"*; do
      [[ -f "$f" ]] && safe_copy "$f" "$CNX_TEMPLATES/$tpl_name/$(basename "$f")" true
    done
    for f in "$tpl_dir".*; do
      [[ -f "$f" ]] && [[ "$(basename "$f")" != "." ]] && [[ "$(basename "$f")" != ".." ]] && \
        safe_copy "$f" "$CNX_TEMPLATES/$tpl_name/$(basename "$f")" true
    done
  done

  info "Resetting skills..."
  mkdir -p "$CNX_HOME/skills"
  for skill_dir in "$REPO_ROOT"/skills/*/; do
    if [[ -d "$skill_dir" ]]; then
      local skill_name
      skill_name="$(basename "$skill_dir")"
      mkdir -p "$CNX_HOME/skills/$skill_name"
      for f in "$skill_dir"*; do
        [[ -f "$f" ]] && cp "$f" "$CNX_HOME/skills/$skill_name/$(basename "$f")"
      done
    fi
  done

  # Re-install global git hook
  local hook_src="$REPO_ROOT/hooks/prepare-commit-msg"
  local hook_dst="$HOME/.config/git/hooks/prepare-commit-msg"
  if [[ -f "$hook_src" ]]; then
    safe_copy "$hook_src" "$hook_dst" true
    chmod +x "$hook_dst"
    ok "Global git hook updated"
  fi

  echo ""
  ok "Reset complete. Syncing to AI tools..."
  echo ""
  cmd_sync true
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: status
# Show current state of conventions
# ═══════════════════════════════════════════════════════════════════════════════
cmd_status() {
  echo -e "${BOLD}Cybernetix Convention Status${NC}"
  echo ""

  # Check ~/.cybernetix
  if [[ -d "$CNX_HOME" ]]; then
    ok "~/.cybernetix/ exists"
  else
    err "~/.cybernetix/ not found — run 'cybernetix setup'"
    return
  fi

  # Check global conventions
  echo ""
  echo -e "${BOLD}Global conventions:${NC}"
  for f in AGENTS.md CLAUDE.md GEMINI.md .cursor-rules; do
    if [[ -f "$CNX_GLOBAL/$f" ]]; then
      echo -e "  ${GREEN}+${NC} $f"
    else
      echo -e "  ${RED}-${NC} $f (missing)"
    fi
  done

  # Check skills
  echo ""
  echo -e "${BOLD}Global skills:${NC}"
  if [[ -d "$CNX_HOME/skills" ]]; then
    local count
    count=$(find "$CNX_HOME/skills" -maxdepth 1 -type d | wc -l | tr -d ' ')
    count=$((count - 1)) # Subtract . itself
    echo -e "  ${GREEN}+${NC} ~/.cybernetix/skills ($count skills installed)"
  else
    echo -e "  ${RED}-${NC} ~/.cybernetix/skills (missing)"
  fi

  # Check sync targets
  echo ""
  echo -e "${BOLD}Sync targets:${NC}"

  local claude_target kimi_target codex_target gemini_target
  claude_target="$(config_get sync_claude ~/.claude/CLAUDE.md)"
  kimi_target="$(config_get sync_kimi ~/.kimi/AGENTS.md)"
  codex_target="$(config_get sync_codex ~/.codex/AGENTS.md)"
  gemini_target="$(config_get sync_gemini ~/.gemini/GEMINI.md)"

  check_sync_status "Claude Code" "$CNX_GLOBAL/CLAUDE.md" "$claude_target"
  check_sync_status "Kimi Code"   "$CNX_GLOBAL/AGENTS.md"  "$kimi_target"
  check_sync_status "Codex"       "$CNX_GLOBAL/AGENTS.md"  "$codex_target"
  check_sync_status "Gemini CLI"  "$CNX_GLOBAL/GEMINI.md"  "$gemini_target"

  # Check skill symlinks
  echo ""
  echo -e "${BOLD}Skill symlinks:${NC}"
  local ai_dirs=(~/.claude ~/.gemini ~/.kimi ~/.codex ~/.cursor)
  for ai_dir in "${ai_dirs[@]}"; do
    ai_dir=$(eval echo "$ai_dir")
    if [[ -d "$ai_dir" ]]; then
      local name
      name=$(basename "$ai_dir" | sed 's/^\.//')
      # Use tr for capitalization to support older bash versions
      name=$(echo "$name" | tr '[:lower:]' '[:upper:]' | cut -c1)$(echo "$name" | cut -c2-)
      local target_link="$ai_dir/skills"
      if [[ -L "$target_link" ]]; then
        local current_target
        current_target="$(readlink "$target_link")"
        if [[ "$current_target" == "$CNX_HOME/skills" ]]; then
          echo -e "  ${GREEN}=${NC} $name: ${target_link/#$HOME/~} (in sync)"
        else
          echo -e "  ${YELLOW}~${NC} $name: ${target_link/#$HOME/~} (points to $current_target)"
        fi
      elif [[ -e "$target_link" ]]; then
        echo -e "  ${RED}!${NC} $name: ${target_link/#$HOME/~} (exists but not a link)"
      else
        echo -e "  ${RED}-${NC} $name: ${target_link/#$HOME/~} (not linked)"
      fi
    fi
  done

  # Check global git hook
  echo ""
  echo -e "${BOLD}Git hook:${NC}"
  local hook_dst="$HOME/.config/git/hooks/prepare-commit-msg"
  local hooks_path
  hooks_path=$(git config --global core.hooksPath 2>/dev/null)
  if [[ -f "$hook_dst" ]] && [[ "$hooks_path" == "$HOME/.config/git/hooks" ]]; then
    echo -e "  ${GREEN}+${NC} prepare-commit-msg (global, AI client auto-detect)"
  elif [[ -f "$hook_dst" ]]; then
    echo -e "  ${YELLOW}~${NC} prepare-commit-msg exists but core.hooksPath not set"
    echo -e "      run: git config --global core.hooksPath ~/.config/git/hooks"
  else
    echo -e "  ${RED}-${NC} not installed — run 'cybernetix setup'"
  fi

  # Check templates
  echo ""
  echo -e "${BOLD}Templates:${NC}"
  for tpl in fullstack frontend-only backend-service cli; do
    if [[ -d "$CNX_TEMPLATES/$tpl" ]]; then
      local count
      count=$(find "$CNX_TEMPLATES/$tpl" -type f | wc -l | tr -d ' ')
      echo -e "  ${GREEN}+${NC} $tpl ($count files)"
    else
      echo -e "  ${RED}-${NC} $tpl (missing)"
    fi
  done
}

check_sync_status() {
  local name="$1"
  local src="$2"
  local dst="$3"

  local display="${dst/#$HOME/~}"
  if [[ ! -f "$dst" ]]; then
    echo -e "  ${RED}-${NC} $name: $display (not synced)"
  elif diff -q "$src" "$dst" &>/dev/null 2>&1; then
    echo -e "  ${GREEN}=${NC} $name: $display (in sync)"
  else
    echo -e "  ${YELLOW}~${NC} $name: $display (out of sync)"
  fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════════════════════
usage() {
  echo -e "${BOLD}Cybernetix${NC} v${VERSION} — AI Agent Convention Manager"
  echo ""
  echo "Usage: cybernetix <command> [options]"
  echo ""
  echo "Commands:"
  echo "  setup              Initialize ~/.cybernetix/ on this machine"
  echo "  sync               Distribute global conventions to AI tool config paths"
  echo "  update             Edit global conventions, then sync"
  echo "  update-skills      Refresh skills in ~/.cybernetix/skills from repo source"
  echo "  init [dir] [type]  Initialize project with convention files"
  echo "  reset              Reset ~/.cybernetix/ from repo source, then sync"
  echo "  status             Show current state of conventions and sync"
  echo ""
  echo "Init options:"
  echo "  Types: fullstack, frontend-only, backend-service, cli"
  echo "  Tools: pass 3rd arg as comma-separated list (claude,gemini,cursor,all)"
  echo ""
  echo "Examples:"
  echo "  cybernetix setup                           # First-time setup"
  echo "  cybernetix sync                            # After editing global conventions"
  echo "  cybernetix update-skills                   # Refresh skills from repo"
  echo "  cybernetix init .                          # Interactive prompts"
  echo "  cybernetix init my-app fullstack claude    # Claude Code only"
  echo "  cybernetix init . cli claude,cursor        # CLI project, Claude + Cursor"
}

main() {
  local cmd="${1:-}"
  shift || true

  case "$cmd" in
    setup)         cmd_setup "$@" ;;
    sync)          cmd_sync "$@" ;;
    update)        cmd_update "$@" ;;
    update-skills|update_skills) cmd_update_skills "$@" ;;
    init)          cmd_init "$@" ;;
    reset)         cmd_reset "$@" ;;
    status)        cmd_status "$@" ;;
    version|--version|-v) echo "cybernetix v${VERSION}" ;;
    help|--help|-h|"") usage ;;
    *)
      err "Unknown command: $cmd"
      echo ""
      usage
      exit 1
      ;;
  esac
}

main "$@"
