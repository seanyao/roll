#!/usr/bin/env bash
set -euo pipefail

# Roll — AI Agent Convention Manager
# Single source of truth for how all AI coding agents behave.

VERSION="0.2.0"
ROLL_HOME="${ROLL_HOME:-${HOME}/.roll}"
ROLL_CONFIG="${ROLL_HOME}/config.yaml"
ROLL_GLOBAL="${ROLL_HOME}/conventions/global"
ROLL_TEMPLATES="${ROLL_HOME}/conventions/templates"

# Find repo root (resolve symlinks so it works from ~/.local/bin/roll)
_source="${BASH_SOURCE[0]}"
while [[ -L "$_source" ]]; do
  _dir="$(cd "$(dirname "$_source")" && pwd)"
  _source="$(readlink "$_source")"
  [[ "$_source" != /* ]] && _source="$_dir/$_source"
done
SCRIPT_DIR="$(cd "$(dirname "$_source")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
REPO_CONVENTIONS="${REPO_ROOT}/conventions"

# Colors
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
NC=$'\033[0m'

# Respect NO_COLOR
if [[ -n "${NO_COLOR:-}" ]]; then
  RED='' GREEN='' YELLOW='' CYAN='' BOLD='' NC=''
fi

info()  { echo -e "${CYAN}[roll]${NC} $*"; }
ok()    { echo -e "${GREEN}[roll]${NC} $*"; }
warn()  { echo -e "${YELLOW}[roll]${NC} $*"; }
err()   { echo -e "${RED}[roll]${NC} $*" >&2; }

# Tracks merge actions across a single init run; reset before each batch
_WK_MERGE_SUMMARY=()

canonical_dir() {
  local path="$1"
  [[ -d "$path" ]] || return 1
  (cd "$path" >/dev/null 2>&1 && pwd -P)
}

# Return a human-readable name for an AI tool dir.
# Handles nested paths like ~/.openclaw/workspace → "openclaw".
ai_tool_name() {
  local dir="$1"
  local bn
  bn="$(basename "$dir" | sed 's/^\.//')"
  if [[ "$bn" == "workspace" ]]; then
    bn="$(basename "$(dirname "$dir")" | sed 's/^\.//')"
  fi
  echo "$bn"
}

lower_name() {
  echo "$1" | tr '[:upper:]' '[:lower:]'
}

# ─── Helper: read config value ───────────────────────────────────────────────
config_get() {
  local key="$1"
  local default="${2:-}"
  if [[ -f "$ROLL_CONFIG" ]]; then
    local val
    val=$(grep -E "^${key}:" "$ROLL_CONFIG" 2>/dev/null | head -1 | sed 's/^[^:]*:[[:space:]]*//' | sed 's/[[:space:]]*$//')
    if [[ -n "$val" ]]; then
      echo "${val/#\~/$HOME}"
      return
    fi
  fi
  echo "${default/#\~/$HOME}"
}

# ─── Helpers: read ai_* entries from config ──────────────────────────────────
# Returns one "dir|config_file|convention_src" line per ai_* key in config.yaml
_get_ai_tools() {
  grep -E "^ai_[a-z]+:" "$ROLL_CONFIG" 2>/dev/null | sed 's/^[^:]*:[[:space:]]*//' | while IFS= read -r entry; do
    echo "${entry/#\~/$HOME}"
  done
}

# Extract fields from a "<dir>|<config>|<src>" entry
_ai_dir()    { echo "$1" | cut -d'|' -f1; }
_ai_config() { echo "$1" | cut -d'|' -f2; }
_ai_src()    { echo "$1" | cut -d'|' -f3; }

# ─── Helper: safe copy with overwrite prompt ─────────────────────────────────
safe_copy() {
  local src="$1"
  local dst="$2"
  local force="${3:-false}"

  if [[ ! -f "$src" ]]; then
    return
  fi

  local dst_dir
  dst_dir="$(dirname "$dst")"
  mkdir -p "$dst_dir"

  if [[ -f "$dst" ]] && [[ "$force" != "true" ]]; then
    if diff -q "$src" "$dst" &>/dev/null; then
      return  # identical, skip silently
    fi
    echo ""
    warn "File exists and differs: ${dst/#$HOME/~}  文件已存在且内容不同: ${dst/#$HOME/~}"
    echo -e "  ${BOLD}Overwrite?${NC} [y/N/d(iff)] "
    read -r answer
    case "$answer" in
      d|D|diff)
        diff --color=auto "$dst" "$src" || true
        echo ""
        echo -e "  ${BOLD}Overwrite?${NC} [y/N] "
        read -r answer2
        [[ "$answer2" =~ ^[Yy]$ ]] || { info "Skipped: ${dst/#$HOME/\~}  已跳过: ${dst/#$HOME/\~}"; return; }
        ;;
      y|Y) ;;
      *) info "Skipped: ${dst/#$HOME/~}  已跳过: ${dst/#$HOME/~}"; return ;;
    esac
  fi

  cp "$src" "$dst"
  ok "Wrote: ${dst/#$HOME/~}  已写入: ${dst/#$HOME/~}"
}

# ─── Internal: pull skills from repo → ~/.roll/skills ──────────────────────
_pull_skills() {
  if [[ ! -d "$REPO_ROOT/skills" ]]; then
    err "Skills source not found at: $REPO_ROOT/skills  技能源目录未找到: $REPO_ROOT/skills"
    return 1
  fi

  mkdir -p "$ROLL_HOME/skills"

  # Copy/update skills from repo → ~/.roll/skills/
  for skill_dir in "$REPO_ROOT"/skills/*/; do
    if [[ -d "$skill_dir" ]]; then
      local skill_name
      skill_name="$(basename "$skill_dir")"
      mkdir -p "$ROLL_HOME/skills/$skill_name"
      for f in "$skill_dir"*; do
        [[ -f "$f" ]] && cp "$f" "$ROLL_HOME/skills/$skill_name/$(basename "$f")"
      done
    fi
  done

  # Prune skills that no longer exist in repo.
  # ~/.roll/skills/ is roll's controlled namespace — safe to clean up.
  for installed_dir in "$ROLL_HOME/skills"/*/; do
    [[ -d "$installed_dir" ]] || continue
    local installed_name
    installed_name="$(basename "$installed_dir")"
    if [[ ! -d "$REPO_ROOT/skills/$installed_name" ]]; then
      rm -rf "$installed_dir"
      info "Removed stale skill: $installed_name  已删除过时技能: $installed_name"
    fi
  done
}

# ─── Internal: pull conventions from repo → ~/.roll/conventions ────────────
_pull_conventions() {
  if [[ ! -d "$REPO_CONVENTIONS" ]]; then
    err "Convention source not found at: $REPO_CONVENTIONS  约定源文件未找到: $REPO_CONVENTIONS"
    return 1
  fi

  mkdir -p "$ROLL_GLOBAL"
  mkdir -p "$ROLL_TEMPLATES"/{fullstack,frontend-only,backend-service,cli}

  info "Copying global conventions...  正在复制全局约定..."
  for f in "$REPO_CONVENTIONS"/global/*; do
    [[ -f "$f" ]] && safe_copy "$f" "$ROLL_GLOBAL/$(basename "$f")"
  done
  for f in "$REPO_CONVENTIONS"/global/.*; do
    [[ -f "$f" ]] && [[ "$(basename "$f")" != "." ]] && [[ "$(basename "$f")" != ".." ]] && \
      safe_copy "$f" "$ROLL_GLOBAL/$(basename "$f")"
  done

  info "Copying project templates...  正在复制项目模板..."
  for tpl_dir in "$REPO_CONVENTIONS"/templates/*/; do
    local tpl_name
    tpl_name="$(basename "$tpl_dir")"
    for f in "$tpl_dir"*; do
      [[ -f "$f" ]] && safe_copy "$f" "$ROLL_TEMPLATES/$tpl_name/$(basename "$f")"
    done
    for f in "$tpl_dir".*; do
      [[ -f "$f" ]] && [[ "$(basename "$f")" != "." ]] && [[ "$(basename "$f")" != ".." ]] && \
        safe_copy "$f" "$ROLL_TEMPLATES/$tpl_name/$(basename "$f")"
    done
  done
}

# ─── Internal: install local cache from repo source ───────────────────────────
_install_local() {
  local force="${1:-false}"

  if [[ ! -d "$REPO_CONVENTIONS" ]]; then
    err "Convention source not found at: $REPO_CONVENTIONS  约定源文件未找到: $REPO_CONVENTIONS"
    err "Run this from the roll repo, or symlink bin/roll to PATH.  请在 roll 仓库目录下运行，或将 bin/roll 软链接到 PATH。"
    exit 1
  fi

  _pull_conventions
  _pull_skills

  # Create config if it doesn't exist
  if [[ ! -f "$ROLL_CONFIG" ]]; then
    info "Creating default config...  正在创建默认配置..."
    cat > "$ROLL_CONFIG" << 'YAML'
# Roll Configuration
# Edit this file, then run `roll sync` to apply.

# AI tools — each entry controls both convention sync and skill linking
# Format: <name>: <dir>|<config_file>|<convention_src>
ai_claude: ~/.claude|CLAUDE.md|CLAUDE.md
ai_gemini: ~/.gemini|GEMINI.md|GEMINI.md
ai_kimi: ~/.kimi|AGENTS.md|AGENTS.md
ai_codex: ~/.codex|AGENTS.md|AGENTS.md
ai_cursor: ~/.cursor|.cursor-rules|.cursor-rules
ai_openclaw: ~/.openclaw/workspace|AGENTS.md|AGENTS.md

# User preferences
default_language: zh
default_project_type: fullstack
editor: ${EDITOR:-vim}
YAML
    ok "Created: ~/.roll/config.yaml  已创建: ~/.roll/config.yaml"
  fi

}

# ─── Internal: create or repair per-skill symlinks (non-destructive) ─────────
_link_skills() {
  local force="${1:-false}"
  local wk_skills_real repo_skills_real
  wk_skills_real="$(canonical_dir "$ROLL_HOME/skills" 2>/dev/null || true)"
  repo_skills_real="$(canonical_dir "$REPO_ROOT/skills" 2>/dev/null || true)"

  while IFS= read -r entry; do
    local ai_dir
    ai_dir="$(_ai_dir "$entry")"
    [[ -d "$ai_dir" ]] || continue

    local ai_name ai_dir_real skills_dir
    ai_name="$(ai_tool_name "$ai_dir")"
    ai_dir_real="$(canonical_dir "$ai_dir" 2>/dev/null || true)"
    skills_dir="$ai_dir/skills"

    if [[ -n "$ai_dir_real" && \
          ( "$ai_dir_real" == "$REPO_ROOT" || "$ai_dir_real" == "$REPO_ROOT"/* ) ]]; then
      warn "Skipped ~/${ai_name} (resolves to repo — refusing to manage skills inside roll worktree)  已跳过 ~/${ai_name}（解析到仓库目录 — 拒绝在 roll worktree 内管理技能）"
      continue
    fi

    # Guard: resolve ALL symlink chains — block writing anywhere inside the repo
    local skills_real
    skills_real="$(canonical_dir "$skills_dir" 2>/dev/null || true)"
    if [[ -n "$skills_real" && -n "$repo_skills_real" && \
          ( "$skills_real" == "$repo_skills_real" || "$skills_real" == "$repo_skills_real"/* ) ]]; then
      warn "Skipped ~/${ai_name}/skills (resolves to repo — check if ~/$(lower_name "$ai_name") symlinks to roll repo)  已跳过 ~/${ai_name}/skills（解析到仓库 — 检查 ~/$(lower_name "$ai_name") 是否软链接到 roll 仓库）"
      continue
    fi

    # Handle legacy whole-dir symlink
    if [[ -L "$skills_dir" ]]; then
      local skills_target
      skills_target="$(readlink "$skills_dir")"
      if [[ -n "$skills_real" && "$skills_real" == "$wk_skills_real" ]]; then
        continue  # Whole-dir symlink to WK skills — still functional
      fi
      # Dangling or stale symlink (e.g. old ~/.cybernetix/skills) — remove and recreate as per-skill links
      if [[ -z "$skills_real" ]]; then
        info "Removing dangling symlink ~/${ai_name}/skills -> ${skills_target/#$HOME/~}  正在移除悬空软链接 ~/${ai_name}/skills -> ${skills_target/#$HOME/~}"
        rm "$skills_dir"
      else
        warn "Skipped ~/${ai_name}/skills -> ${skills_target/#$HOME/~} (unknown symlink target)  已跳过 ~/${ai_name}/skills -> ${skills_target/#$HOME/~}（未知软链接目标）"
        continue
      fi
    fi

    mkdir -p "$skills_dir"
    skills_real="$(canonical_dir "$skills_dir" 2>/dev/null || true)"
    if [[ -n "$skills_real" && -n "$repo_skills_real" && \
          ( "$skills_real" == "$repo_skills_real" || "$skills_real" == "$repo_skills_real"/* ) ]]; then
      warn "Skipped ~/${ai_name}/skills (created path resolves to repo — refusing to write)  已跳过 ~/${ai_name}/skills（创建路径解析到仓库 — 拒绝写入）"
      continue
    fi
    local linked=0 repaired=0 pruned=0

    # Prune stale wk-* symlinks pointing to skills no longer in ~/.roll/skills/
    for link in "$skills_dir"/wk-*; do
      [[ -L "$link" ]] || continue
      local link_target
      link_target="$(readlink "$link")"
      # Only remove symlinks we own (pointing into our skills dir)
      if [[ "$link_target" == "$ROLL_HOME/skills/"* ]] && [[ ! -d "$link" ]]; then
        rm "$link"
        pruned=$((pruned + 1))
      fi
    done

    for skill_dir in "$ROLL_HOME/skills"/*/; do
      [[ -d "$skill_dir" ]] || continue
      local skill_name
      skill_name="$(basename "$skill_dir")"
      local skill_link="$skills_dir/$skill_name"

      if [[ -L "$skill_link" ]]; then
        local current_target
        current_target="$(readlink "$skill_link")"
        if [[ "$current_target" != "$skill_dir" ]]; then
          ln -sf "$skill_dir" "$skill_link"
          repaired=$((repaired + 1))
        fi
        # correct symlink: skip silently
      elif [[ ! -e "$skill_link" ]]; then
        ln -s "$skill_dir" "$skill_link"
        linked=$((linked + 1))
      fi
      # real file/dir at that path: skip — never touch user content
    done
    if [[ $((linked + repaired + pruned)) -gt 0 ]]; then
      ok "Skills linked in ~/${ai_name}/skills (+${linked} new, ~${repaired} repaired, -${pruned} pruned)  已在 ~/${ai_name}/skills 中创建软链接（新增 +${linked}，修复 ~${repaired}，清理 -${pruned}）"
    fi
  done < <(_get_ai_tools)
}

# ─── Internal: sync conventions via @include — never overwrites user files ─────
# Writes WK content to {ai_dir}/wk.md, appends @wk.md to main config.
_sync_convention_for_tool() {
  local src="$1"       # source: ~/.roll/conventions/global/CLAUDE.md
  local main_dst="$2"  # target: ~/.claude/CLAUDE.md
  local force="$3"

  [[ -f "$src" ]] || return
  local dst_dir
  dst_dir="$(dirname "$main_dst")"

  # Only proceed if the AI tool directory already exists (except Claude, always create)
  if [[ "$dst_dir" != "$HOME/.claude" ]] && [[ ! -d "$dst_dir" ]]; then
    return
  fi
  mkdir -p "$dst_dir"

  # Write/update wk.md — this is our file, always safe to overwrite
  local wk_file="$dst_dir/wk.md"
  if [[ "$force" == "true" ]] || ! diff -q "$src" "$wk_file" &>/dev/null 2>&1; then
    cp "$src" "$wk_file"
    ok "Wrote: ${wk_file/#$HOME/~}  已写入: ${wk_file/#$HOME/~}"
  fi

  # Append @wk.md include to main config — never overwrite existing content
  if [[ ! -f "$main_dst" ]]; then
    printf '@wk.md\n' > "$main_dst"
    ok "Created: ${main_dst/#$HOME/~}  已创建: ${main_dst/#$HOME/~}"
  elif ! grep -qF "@wk.md" "$main_dst" 2>/dev/null; then
    printf '\n@wk.md\n' >> "$main_dst"
    ok "Appended @wk.md to: ${main_dst/#$HOME/~}  已将 @wk.md 追加至: ${main_dst/#$HOME/~}"
  else
    ok "Already included: ${main_dst/#$HOME/~}  已包含: ${main_dst/#$HOME/~}"
  fi
}

_sync_conventions() {
  local force="${1:-false}"

  while IFS= read -r entry; do
    local ai_dir config_file src_file
    ai_dir="$(_ai_dir "$entry")"
    config_file="$(_ai_config "$entry")"
    src_file="$(_ai_src "$entry")"
    _sync_convention_for_tool "$ROLL_GLOBAL/$src_file" "$ai_dir/$config_file" "$force"
  done < <(_get_ai_tools)
}

# ─── Internal: sync skills (pull + link) ──────────────────────────────────────
_sync_skills() {
  local force="${1:-false}"
  info "Updating skills...  正在更新技能..."
  _pull_skills
  ok "Skills updated in ~/.roll/skills  技能已更新至 ~/.roll/skills"
  info "Creating skill symlinks for AI tools...  正在为 AI 工具创建技能软链接..."
  _link_skills "$force"
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: setup
# Initialize ~/.roll/ on a new machine
# ═══════════════════════════════════════════════════════════════════════════════
cmd_setup() {
  info "Setting up Roll on this machine...  正在初始化 Roll..."
  echo ""

  _install_local
  echo ""
  _sync_skills

  echo ""
  ok "Setup complete. Skills installed in ~/.roll/  初始化完成。技能已安装至 ~/.roll/"
  echo ""
  info "Next steps:  后续步骤："
  echo "  Init a project:          ${BOLD}roll init${NC}                 初始化项目"
  echo "  Add global conventions:  ${BOLD}roll sync conventions${NC}     添加全局约定"
  echo "  Install git hook:        ${BOLD}roll hook install${NC}        安装 git hook"
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: sync [scope] [--force]
# Distribute global conventions and/or skills to each AI tool's config path
# Scopes: conventions (default), skills, all
# ═══════════════════════════════════════════════════════════════════════════════
cmd_sync() {
  if [[ ! -d "$ROLL_HOME" ]]; then
    err "~/.roll/ not found. Run 'roll setup' first.  ~/.roll/ 不存在，请先运行 'roll setup'。"
    exit 1
  fi

  local scope="conventions"
  local force=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force|-f) force=true; shift ;;
      conventions|skills|all) scope="$1"; shift ;;
      *) err "Unknown sync argument: $1  未知同步参数: $1"; exit 1 ;;
    esac
  done

  info "Syncing ${scope}...  正在同步 ${scope}..."
  echo ""

  if [[ "$scope" == "conventions" || "$scope" == "all" ]]; then
    _sync_conventions "$force"
  fi
  if [[ "$scope" == "skills" || "$scope" == "all" ]]; then
    _sync_skills "$force"
  fi

  echo ""
  ok "Sync complete.  同步完成。"
}

# ─── Helper: show full type menu and return chosen type ──────────────────────
_select_project_type() {
  echo ""
  echo -e "${BOLD}Select project type:${NC}"
  echo ""
  echo "  1) fullstack        React + API + CLI"
  echo "  2) frontend-only    React SPA, no backend"
  echo "  3) backend-service  API/microservice, no frontend"
  echo "  4) cli              Command-line tool"
  echo ""
  echo -n "Choice [1-4]: "
  read -r choice
  case "$choice" in
    1) echo "fullstack" ;;
    2) echo "frontend-only" ;;
    3) echo "backend-service" ;;
    4) echo "cli" ;;
    *) err "Invalid choice: $choice  无效选择: $choice"; exit 1 ;;
  esac
}

# ─── Helper: resolve AI tool flags from arg or interactive prompt ─────────────
# Sets _WK_USE_CLAUDE / _WK_USE_GEMINI / _WK_USE_CURSOR in caller's scope.
# Usage: _select_tools "<tools_arg>"   (empty string = interactive)
_select_tools() {
  local tools_arg="${1:-}"
  _WK_USE_CLAUDE=false
  _WK_USE_GEMINI=false
  _WK_USE_CURSOR=false

  if [[ -n "$tools_arg" ]]; then
    IFS=',' read -ra tool_list <<< "$tools_arg"
    for t in "${tool_list[@]}"; do
      case "$t" in
        claude) _WK_USE_CLAUDE=true ;;
        gemini) _WK_USE_GEMINI=true ;;
        cursor) _WK_USE_CURSOR=true ;;
        all)    _WK_USE_CLAUDE=true; _WK_USE_GEMINI=true; _WK_USE_CURSOR=true ;;
        *) warn "Unknown tool: $t  未知工具: $t" ;;
      esac
    done
  else
    echo ""
    echo -e "${BOLD}Which AI tools do you use?${NC} (space-separated, or 'a' for all)"
    echo ""
    echo "  c) Claude Code"
    echo "  g) Gemini CLI"
    echo "  k) Kimi        (uses AGENTS.md)"
    echo "  r) Cursor IDE"
    echo "  a) All of the above"
    echo ""
    echo -n "Choice [c/g/k/r/a] (default: c): "
    read -r tool_choice
    tool_choice="${tool_choice:-c}"
    for ch in $tool_choice; do
      case "$ch" in
        c) _WK_USE_CLAUDE=true ;;
        g) _WK_USE_GEMINI=true ;;
        k) ;;  # Kimi reuses AGENTS.md — no extra file needed
        r) _WK_USE_CURSOR=true ;;
        a) _WK_USE_CLAUDE=true; _WK_USE_GEMINI=true; _WK_USE_CURSOR=true ;;
      esac
    done
  fi
}

# ─── Helper: non-interactive auto-scan mode (CI / scripts) ───────────────────
# Scans project files to resolve type; echoes the resolved type.
_init_auto() {
  local project_dir="$1"
  info "Scanning project files...  正在扫描项目文件..."
  local detected_type
  detected_type="$(scan_project_type_from_files "$project_dir")"
  if [[ "$detected_type" == "unknown" ]]; then
    warn "Cannot determine project type from files. Defaulting to 'fullstack'.  无法从文件判断项目类型，默认使用 'fullstack'。"
    echo "fullstack"
  else
    ok "Detected: ${BOLD}$detected_type${NC}  已检测到: ${BOLD}$detected_type${NC}"
    echo "$detected_type"
  fi
}

# ─── Helper: re-merge an already-initialized project from latest templates ───
# Called when AGENTS.md exists and user keeps the detected type.
_init_refresh() {
  local project_dir="$1"
  info "Re-merging from latest templates...  正在从最新模板重新合并..."
  echo ""
  _WK_MERGE_SUMMARY=()
  refresh_project "$project_dir"
  print_merge_summary
  echo ""
  ok "Done.  完成。"
}

# ─── Helper: full new/switch init — tool selection + merge conventions + scaffold
# Expects tools_arg resolved; sets _WK_USE_* via _select_tools then merges.
_init_new() {
  local project_dir="$1"
  local project_type="$2"

  local tpl_dir="$ROLL_TEMPLATES/$project_type"
  if [[ ! -d "$tpl_dir" ]]; then
    err "Template not found: $project_type  模板未找到: $project_type"
    err "Available: fullstack, frontend-only, backend-service, cli, auto  可用类型: fullstack, frontend-only, backend-service, cli, auto"
    exit 1
  fi

  info "Initializing ${BOLD}$project_type${NC} conventions in: $project_dir  正在初始化 ${BOLD}$project_type${NC} 约定，目录: $project_dir"
  echo ""

  _WK_MERGE_SUMMARY=()
  merge_convention "AGENTS.md" "$tpl_dir" "$project_dir" "AGENTS.md"

  if [[ "$_WK_USE_CLAUDE" == "true" ]]; then
    mkdir -p "$project_dir/.claude"
    merge_convention "CLAUDE.md" "$tpl_dir" "$project_dir/.claude" ".claude/CLAUDE.md"
  fi
  if [[ "$_WK_USE_GEMINI" == "true" ]]; then
    merge_convention "GEMINI.md" "$tpl_dir" "$project_dir" "GEMINI.md"
  fi
  if [[ "$_WK_USE_CURSOR" == "true" ]]; then
    merge_convention ".cursor-rules" "$tpl_dir" "$project_dir" ".cursor-rules"
  fi

  ok "Convention files initialized for ${BOLD}$project_type${NC} project.  已为 ${BOLD}$project_type${NC} 项目初始化约定文件。"
  print_merge_summary

  # ── Scaffold phase ───────────────────────────────────────────────────────
  if is_fresh_project "$project_dir"; then
    echo ""
    echo -n "  Scaffold ${BOLD}$project_type${NC} project structure? [Y/n]: "
    read -r _scaffold_ans
    if [[ "${_scaffold_ans:-Y}" =~ ^[Yy]$ ]]; then
      echo ""
      scaffold_new_project "$project_dir" "$project_type"
    fi
  else
    scaffold_legacy_project "$project_dir"
  fi
  echo ""
}

# ─── Helper: interactive type detection + keep-or-switch prompt ──────────────
# Detects project type (AGENTS.md then file scan), prompts user to keep/switch.
# Sets _WK_RESOLVED_TYPE to chosen type.
# Sets _WK_DO_REFRESH=true when AGENTS.md exists and user kept the same type.
_detect_and_prompt_type() {
  local project_dir="$1"
  _WK_DO_REFRESH=false
  local detected=""

  # Try AGENTS.md first, then file scan
  if [[ -f "$project_dir/AGENTS.md" ]]; then
    detected="$(detect_project_type "$project_dir")"
  fi
  if [[ -z "$detected" || "$detected" == "unknown" ]]; then
    detected="$(scan_project_type_from_files "$project_dir")"
  fi

  if [[ -n "$detected" && "$detected" != "unknown" ]]; then
    echo ""
    echo -e "  Detected: ${BOLD}$detected${NC}"
    echo -n "  Keep it? [Y/n] or override [1-4]: "
    read -r answer
    case "$answer" in
      ""|y|Y) _WK_RESOLVED_TYPE="$detected" ;;
      1) _WK_RESOLVED_TYPE="fullstack" ;;
      2) _WK_RESOLVED_TYPE="frontend-only" ;;
      3) _WK_RESOLVED_TYPE="backend-service" ;;
      4) _WK_RESOLVED_TYPE="cli" ;;
      n|N) _WK_RESOLVED_TYPE="$(_select_project_type)" ;;
      *) err "Invalid choice: $answer  无效选择: $answer"; exit 1 ;;
    esac
  else
    # Truly unknown: show full menu
    _WK_RESOLVED_TYPE="$(_select_project_type)"
  fi

  # If AGENTS.md already exists and user kept the same type → refresh path
  if [[ -f "$project_dir/AGENTS.md" && "$_WK_RESOLVED_TYPE" == "$detected" ]]; then
    _WK_DO_REFRESH=true
  fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: init [type] [tools]
# Initialize a project with convention files from a template.
# Always operates on the current directory (cwd).
# Smart mode: if no type given and AGENTS.md already exists → auto-refresh.
# ═══════════════════════════════════════════════════════════════════════════════
cmd_init() {
  if [[ ! -d "$ROLL_TEMPLATES" ]]; then
    err "No templates found. Run 'roll setup' first.  未找到模板，请先运行 'roll setup'。"
    exit 1
  fi

  local project_type="${1:-}"
  local tools_arg="${2:-}"
  local project_dir
  project_dir="$(pwd)"

  # ── Explicit "auto" arg: non-interactive scan (for scripts / CI) ──────────
  if [[ "$project_type" == "auto" ]]; then
    project_type="$(_init_auto "$project_dir")"
  fi

  # ── Interactive mode: detect first, then ask keep-or-switch ───────────────
  if [[ -z "$project_type" ]]; then
    _detect_and_prompt_type "$project_dir"
    if [[ "$_WK_DO_REFRESH" == "true" ]]; then
      _init_refresh "$project_dir"
      return
    fi
    project_type="$_WK_RESOLVED_TYPE"
  fi

  # AI tool selection + full init
  _select_tools "$tools_arg"
  _init_new "$project_dir" "$project_type"
}

# ─── Helper: merge global preamble + template into output ────────────────────
merge_convention() {
  local filename="$1"
  local tpl_dir="$2"
  local out_dir="$3"
  local display="${4:-$filename}"
  local global_file="$ROLL_GLOBAL/$filename"
  local tpl_file="$tpl_dir/$filename"
  local out_file="$out_dir/$filename"

  if [[ ! -f "$tpl_file" ]]; then
    return
  fi

  local merged
  merged="$(cat "$global_file" 2>/dev/null || true)"
  merged+=$'\n\n'
  merged+="---"
  merged+=$'\n\n'
  merged+="$(cat "$tpl_file")"

  if [[ -f "$out_file" ]]; then
    if diff -q <(echo "$merged") "$out_file" &>/dev/null; then
      _WK_MERGE_SUMMARY+=("unchanged|$display")
      return  # identical, nothing to do
    fi
    warn "File exists: $display  文件已存在: $display"
    echo -n "  [o] Overwrite  [k] Keep  [M] Merge (default): "
    read -r answer
    answer="${answer:-M}"
    case "$answer" in
      o|O)
        echo "$merged" > "$out_file"
        ok "Overwritten: $display  已覆盖: $display"
        _WK_MERGE_SUMMARY+=("overwritten|$display")
        return
        ;;
      k|K)
        info "Kept: $display  已保留: $display"
        _WK_MERGE_SUMMARY+=("kept|$display")
        return
        ;;
      m|M|"")
        # Merge: for each ## section in template:
        #   - if missing in output → append
        #   - if present but content differs → show diff, prompt [u/k]
        #   - if present and identical → skip

        # Helper: extract a section's body (lines after heading until next ## or EOF)
        # Usage: _extract_section "$file" "$heading"
        _extract_section() {
          local file="$1"
          local heading="$2"
          local in_section=false
          local body=""
          while IFS= read -r ln; do
            if [[ "$ln" == "$heading" ]]; then
              in_section=true
              continue
            fi
            if [[ "$in_section" == "true" ]]; then
              if [[ "$ln" =~ ^##\  ]]; then
                break
              fi
              body+="$ln"$'\n'
            fi
          done < "$file"
          printf '%s' "$body"
        }

        local current_heading=""
        local current_body=""

        # _process_section: check/append/update a completed section
        _process_section() {
          local heading="$1"
          local body="$2"
          local out="$3"
          if ! grep -qF "$heading" "$out" 2>/dev/null; then
            # Section missing → append
            printf '\n%s\n%s' "$heading" "$body" >> "$out"
          else
            # Section exists → compare content
            local existing
            existing="$(_extract_section "$out" "$heading")"
            if [[ "$body" != "$existing" ]]; then
              echo ""
              warn "Section \"$heading\" exists but content differs:"
              diff <(printf '%s' "$existing") <(printf '%s' "$body") || true
              echo -n "  [u] update with template  [k] keep mine (default): "
              local sec_ans
              read -r sec_ans
              sec_ans="${sec_ans:-k}"
              if [[ "$sec_ans" == "u" || "$sec_ans" == "U" ]]; then
                # Replace existing section with template section
                local tmp_out
                tmp_out="$(mktemp)"
                local skip=false
                while IFS= read -r fline; do
                  if [[ "$fline" == "$heading" ]]; then
                    skip=true
                    printf '%s\n%s' "$heading" "$body" >> "$tmp_out"
                    continue
                  fi
                  if [[ "$skip" == "true" ]]; then
                    if [[ "$fline" =~ ^##\  ]]; then
                      skip=false
                      printf '%s\n' "$fline" >> "$tmp_out"
                    fi
                    continue
                  fi
                  printf '%s\n' "$fline" >> "$tmp_out"
                done < "$out"
                mv "$tmp_out" "$out"
              fi
            fi
          fi
        }

        # Parse template sections, reading from file (not herestring) to keep stdin free
        # for interactive user prompts inside _process_section
        local tpl_sections=()
        local tpl_bodies=()
        local cur_h="" cur_b=""
        while IFS= read -r line; do
          if [[ "$line" =~ ^##\  ]]; then
            if [[ -n "$cur_h" ]]; then
              tpl_sections+=("$cur_h")
              tpl_bodies+=("$cur_b")
            fi
            cur_h="$line"
            cur_b=""
          elif [[ -n "$cur_h" ]]; then
            cur_b+="$line"$'\n'
          fi
        done < "$tpl_file"
        # Capture last section
        if [[ -n "$cur_h" ]]; then
          tpl_sections+=("$cur_h")
          tpl_bodies+=("$cur_b")
        fi

        # Now process sections (stdin is free for user input)
        local i
        for (( i=0; i<${#tpl_sections[@]}; i++ )); do
          _process_section "${tpl_sections[$i]}" "${tpl_bodies[$i]}" "$out_file"
        done

        ok "Merged: $display  已合并: $display"
        _WK_MERGE_SUMMARY+=("merged|$display")
        return
        ;;
    esac
  fi

  echo "$merged" > "$out_file"
  ok "Created: $display  已创建: $display"
  _WK_MERGE_SUMMARY+=("created|$display")
}

# ─── Helper: print a tidy summary of merge actions ───────────────────────────
print_merge_summary() {
  if [[ ${#_WK_MERGE_SUMMARY[@]} -eq 0 ]]; then
    return
  fi
  echo ""
  echo "  ┌─ 操作摘要 Summary ──────────────────────────────────┐"
  for entry in "${_WK_MERGE_SUMMARY[@]}"; do
    local action="${entry%%|*}"
    local file="${entry##*|}"
    case "$action" in
      merged)      printf "  │  ${GREEN}✦ merged${NC}      %-30s│\n" "$file" ;;
      created)     printf "  │  ${GREEN}+ created${NC}     %-30s│\n" "$file" ;;
      overwritten) printf "  │  ${YELLOW}↺ overwritten${NC} %-30s│\n" "$file" ;;
      kept)        printf "  │  ${CYAN}· kept${NC}        %-30s│\n" "$file" ;;
      unchanged)   printf "  │    unchanged    %-30s│\n" "$file" ;;
    esac
  done
  echo "  └─────────────────────────────────────────────────────┘"
}

# ─── Helper: auto-detect project type by scanning project files ──────────────
scan_project_type_from_files() {
  local dir="${1:-.}"
  local has_frontend=false
  local has_backend=false
  local has_cli=false

  # Frontend signals
  if [[ -f "$dir/package.json" ]]; then
    grep -qiE '"react"|"vue"|"next"|"nuxt"|"vite"|"svelte"' "$dir/package.json" 2>/dev/null \
      && has_frontend=true
  fi
  [[ -d "$dir/src" || -d "$dir/app" || -d "$dir/pages" || -d "$dir/components" ]] \
    && has_frontend=true

  # Backend/API signals
  [[ -d "$dir/server" || -d "$dir/api" || -d "$dir/backend" ]] && has_backend=true
  [[ -f "$dir/go.mod" || -f "$dir/main.go" || -f "$dir/main.py" || -f "$dir/app.py" \
    || -f "$dir/Cargo.toml" || -f "$dir/requirements.txt" || -f "$dir/pyproject.toml" ]] \
    && has_backend=true
  # DB/ORM/server-side deps in package.json → backend signal
  if [[ -f "$dir/package.json" ]]; then
    grep -qiE '"prisma"|"@prisma/client"|"typeorm"|"sequelize"|"mongoose"|"drizzle-orm"|"@neondatabase/serverless"|"pg"|"mysql2"|"mongodb"|"redis"|"ioredis"|"express"|"fastify"|"koa"|"hapi"|"@hapi/hapi"|"apollo-server"|"graphql-yoga"|"trpc"' "$dir/package.json" 2>/dev/null \
      && has_backend=true
  fi
  # Prisma schema file is a definitive backend signal
  [[ -f "$dir/prisma/schema.prisma" ]] && has_backend=true

  # CLI signals (bin/ with executables, or cmd/ layout common in Go CLIs)
  [[ -d "$dir/bin" || -d "$dir/cmd" ]] && has_cli=true

  # Determine type
  if $has_frontend && $has_backend; then
    echo "fullstack"
  elif $has_frontend && ! $has_backend; then
    echo "frontend-only"
  elif $has_cli && ! $has_frontend; then
    echo "cli"
  elif $has_backend && ! $has_frontend; then
    echo "backend-service"
  else
    echo "unknown"
  fi
}

# ─── Helper: true when cwd has no existing source code ───────────────────────
is_fresh_project() {
  local dir="${1:-.}"
  ! ( [[ -f "$dir/package.json" ]] || [[ -f "$dir/go.mod" ]] || \
      [[ -f "$dir/Cargo.toml" ]] || [[ -f "$dir/requirements.txt" ]] || \
      [[ -f "$dir/pyproject.toml" ]] || \
      [[ -d "$dir/src" ]] || [[ -d "$dir/api" ]] || [[ -d "$dir/app" ]] )
}

# ─── Helper: make a scaffold dir + .gitkeep ───────────────────────────────────
_mkscaffold() { mkdir -p "$1"; touch "$1/.gitkeep"; }

# ─── Helper: write starter BACKLOG.md (no-op if exists) ──────────────────────
_write_backlog() {
  [[ -f "$1" ]] && return
  cat > "$1" << 'EOF'
# Project Backlog

## Epic: Initial Setup
| Story | Description | Status |
|-------|-------------|--------|

## Bug Fixes
| ID | Problem | Status |
|----|---------|--------|
EOF
}

# ─── Helper: write starter .gitignore (no-op if exists) ──────────────────────
_write_gitignore() {
  [[ -f "$1" ]] && return
  cat > "$1" << 'EOF'
node_modules/
dist/
build/
.env
*.local
.DS_Store
*.log
EOF
}

# ─── Helper: write starter .env.example (no-op if exists) ────────────────────
_write_env_example() {
  [[ -f "$1" ]] && return
  cat > "$1" << 'EOF'
# Environment Variables — copy to .env and fill in values

# Application
# NODE_ENV=development
# PORT=3000

# Database
# DATABASE_URL=postgresql://user:pass@localhost:5432/db

# Auth
# JWT_SECRET=your-secret-key
EOF
}

# ─── Scaffold: full structure for new projects (US-INIT-004) ──────────────────
scaffold_new_project() {
  local dir="$1"
  local type="$2"

  info "Scaffolding ${BOLD}$type${NC} project structure...  正在生成 ${BOLD}$type${NC} 项目结构..."
  echo ""

  # Common: docs + workflow backbone
  _mkscaffold "$dir/docs/features"
  _write_backlog  "$dir/BACKLOG.md"
  _write_gitignore "$dir/.gitignore"
  local created="docs/, BACKLOG.md, .gitignore"

  case "$type" in
    fullstack)
      _mkscaffold "$dir/src/components/ui"
      _mkscaffold "$dir/src/domains"
      _mkscaffold "$dir/src/shared"
      _mkscaffold "$dir/api/routes"
      _mkscaffold "$dir/api/services"
      _mkscaffold "$dir/api/models"
      _mkscaffold "$dir/tests/unit"
      _mkscaffold "$dir/tests/e2e"
      _write_env_example "$dir/.env.example"
      created+=", src/, api/, tests/, .env.example"
      ;;
    frontend-only)
      _mkscaffold "$dir/src/components/ui"
      _mkscaffold "$dir/src/domains"
      _mkscaffold "$dir/src/shared"
      _mkscaffold "$dir/tests/unit"
      _mkscaffold "$dir/tests/e2e"
      _write_env_example "$dir/.env.example"
      created+=", src/, tests/, .env.example"
      ;;
    backend-service)
      _mkscaffold "$dir/api/routes"
      _mkscaffold "$dir/api/services"
      _mkscaffold "$dir/api/models"
      _mkscaffold "$dir/tests/unit"
      _mkscaffold "$dir/tests/e2e"
      _write_env_example "$dir/.env.example"
      created+=", api/, tests/, .env.example"
      ;;
    cli)
      _mkscaffold "$dir/cmd"
      _mkscaffold "$dir/lib"
      _mkscaffold "$dir/tests/unit"
      created+=", cmd/, lib/, tests/"
      ;;
  esac

  ok "Scaffolded: $created  已生成: $created"
}

# ─── Scaffold: interactive per-component for legacy projects (US-INIT-005) ────
scaffold_legacy_project() {
  local dir="$1"
  local -a added=()

  echo ""
  info "Existing project detected — add Roll workflow files?  检测到已有项目 — 是否添加 Roll 工作流文件？"
  echo ""

  _ask() {
    echo -n "  Add ${BOLD}$1${NC}  ($2)  [Y/n]: "
    read -r _ans
    [[ "${_ans:-Y}" =~ ^[Yy]$ ]]
  }

  if _ask "BACKLOG.md"              "track stories & bugs in one place"; then
    _write_backlog "$dir/BACKLOG.md"
    added+=("BACKLOG.md")
  fi

  if _ask "docs/features/"          "design docs live next to code"; then
    _mkscaffold "$dir/docs/features"
    _mkscaffold "$dir/docs/plans"
    added+=("docs/")
  fi

  if _ask "tests/ scaffold"         "unit/ e2e/ structure ready to fill"; then
    _mkscaffold "$dir/tests/unit"
    _mkscaffold "$dir/tests/e2e"
    added+=("tests/")
  fi

  if _ask ".env.example"            "document required env vars for teammates"; then
    _write_env_example "$dir/.env.example"
    added+=(".env.example")
  fi

  if _ask ".github/workflows/ci.yml"       "automated CI on every push"; then
    mkdir -p "$dir/.github/workflows"
    cat > "$dir/.github/workflows/ci.yml" << 'EOF'
name: CI
on: [push, pull_request]
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - run: npm ci
      - run: npm test -- --run
EOF
    added+=(".github/workflows/ci.yml")
  fi

  if _ask ".github/workflows/sentinel.yml" "scheduled patrol every 6h"; then
    mkdir -p "$dir/.github/workflows"
    cat > "$dir/.github/workflows/sentinel.yml" << 'EOF'
name: Sentinel Patrol
on:
  schedule:
    - cron: '0 */6 * * *'
  workflow_dispatch:
jobs:
  patrol:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Run sentinel
        run: echo "Configure wk-sentinel patrol here"
EOF
    added+=(".github/workflows/sentinel.yml")
  fi

  echo ""
  if [[ ${#added[@]} -gt 0 ]]; then
    ok "Added: ${added[*]}  已添加: ${added[*]}"
  else
    info "Nothing added.  未添加任何文件。"
  fi
}

# ─── Helper: detect project type from existing AGENTS.md ─────────────────────
detect_project_type() {
  local agents_file="$1/AGENTS.md"
  [[ -f "$agents_file" ]] || { echo "unknown"; return; }

  local content
  content="$(cat "$agents_file")"

  if echo "$content" | grep -qi "Fullstack Web"; then
    echo "fullstack"
  elif echo "$content" | grep -qi "Backend Service"; then
    echo "backend-service"
  elif echo "$content" | grep -qi "Frontend Only"; then
    echo "frontend-only"
  elif echo "$content" | grep -qi "CLI Tool"; then
    echo "cli"
  else
    # AGENTS.md exists but has no type marker — fall back to file-based scan
    scan_project_type_from_files "$1"
  fi
}

# ─── Helper: detect AI tools from existing convention files ──────────────────
detect_tools() {
  local dir="$1"
  local tools=""
  [[ -f "$dir/.claude/CLAUDE.md" ]] && tools+="claude,"
  [[ -f "$dir/GEMINI.md" ]] && tools+="gemini,"
  [[ -f "$dir/.cursor-rules" ]] && tools+="cursor,"
  echo "${tools%,}"
}

# ─── Helper: refresh a single project ────────────────────────────────────────
refresh_project() {
  local project_dir="$1"
  local project_name
  project_name="$(basename "$project_dir")"

  local ptype
  ptype="$(detect_project_type "$project_dir")"

  if [[ "$ptype" == "unknown" ]]; then
    warn "  ${BOLD}$project_name${NC}: cannot detect project type — skipping  无法检测项目类型 — 已跳过"
    return 1
  fi

  local tools
  tools="$(detect_tools "$project_dir")"

  local tpl_dir="$ROLL_TEMPLATES/$ptype"
  if [[ ! -d "$tpl_dir" ]]; then
    warn "  ${BOLD}$project_name${NC}: template '$ptype' not found — skipping  模板 '$ptype' 未找到 — 已跳过"
    return 1
  fi

  info "  ${BOLD}$project_name${NC} ($ptype | ${tools:-AGENTS.md only})  正在处理: ${BOLD}$project_name${NC}"

  merge_convention "AGENTS.md" "$tpl_dir" "$project_dir" "  AGENTS.md"

  if echo "$tools" | grep -q "claude"; then
    mkdir -p "$project_dir/.claude"
    merge_convention "CLAUDE.md" "$tpl_dir" "$project_dir/.claude" "  .claude/CLAUDE.md"
  fi
  if echo "$tools" | grep -q "gemini"; then
    merge_convention "GEMINI.md" "$tpl_dir" "$project_dir" "  GEMINI.md"
  fi
  if echo "$tools" | grep -q "cursor"; then
    merge_convention ".cursor-rules" "$tpl_dir" "$project_dir" "  .cursor-rules"
  fi

  return 0
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: hooks <subcommand>
# Manage the global git hook (opt-in — modifies git global config)
# ═══════════════════════════════════════════════════════════════════════════════
cmd_hook() {
  local subcmd="${1:-install}"

  case "$subcmd" in
    install)
      local hooks_dir="$HOME/.config/git/hooks"
      local hook_src="$REPO_ROOT/hooks/prepare-commit-msg"
      local hook_dst="$hooks_dir/prepare-commit-msg"

      if [[ ! -f "$hook_src" ]]; then
        err "Hook source not found: $hook_src  Hook 源文件未找到: $hook_src"
        exit 1
      fi

      local current_hooks_path
      current_hooks_path=$(git config --global core.hooksPath 2>/dev/null || echo "(not set)")

      echo ""
      warn "This will modify your global git configuration:  此操作将修改您的全局 git 配置："
      echo "  git config --global core.hooksPath $hooks_dir"
      echo ""
      echo "  Current value: $current_hooks_path  当前值: $current_hooks_path"
      echo ""
      if [[ "$current_hooks_path" != "(not set)" ]] && [[ "$current_hooks_path" != "$hooks_dir" ]]; then
        warn "WARNING: Hooks at '$current_hooks_path' will stop running after this change.  警告：此更改后 '$current_hooks_path' 处的 hooks 将不再运行。"
        echo ""
      fi
      echo -n "  Proceed? [y/N] "
      read -r answer
      [[ "$answer" =~ ^[Yy]$ ]] || { info "Aborted.  已取消。"; return; }

      mkdir -p "$hooks_dir"
      cp "$hook_src" "$hook_dst"
      chmod +x "$hook_dst"
      git config --global core.hooksPath "$hooks_dir"
      ok "Global git hook installed (AI client auto-detected on every commit)  全局 git hook 已安装（每次提交自动检测 AI 客户端）"
      ;;
    remove)
      git config --global --unset core.hooksPath 2>/dev/null && \
        ok "Removed core.hooksPath from global git config  已从全局 git 配置中移除 core.hooksPath" || \
        info "core.hooksPath was not set  core.hooksPath 未设置"
      ;;
    *)
      err "Unknown hooks subcommand: $subcmd  未知 hooks 子命令: $subcmd"
      echo "Usage: roll hook [install|remove]  用法: roll hook [install|remove]"
      exit 1
      ;;
  esac
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: reset
# Re-copy conventions and skills from repo source, then sync all with force
# ═══════════════════════════════════════════════════════════════════════════════
cmd_reset() {
  warn "This will overwrite ~/.roll/conventions/ and skills with repo defaults.  此操作将用仓库默认值覆盖 ~/.roll/conventions/ 和技能。"
  echo -n "  Continue? [y/N] "
  read -r answer
  [[ "$answer" =~ ^[Yy]$ ]] || { info "Aborted.  已取消。"; return; }

  echo ""
  info "Resetting local cache from repo...  正在从仓库重置本地缓存..."
  _install_local true

  echo ""
  ok "Reset complete. Force-syncing to AI tools...  重置完成，正在强制同步到 AI 工具..."
  echo ""
  cmd_sync all --force
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: status
# Show current state of conventions
# ═══════════════════════════════════════════════════════════════════════════════
cmd_status() {
  echo -e "${BOLD}Roll Convention Status  Roll 约定状态${NC}"
  echo ""

  if [[ -d "$ROLL_HOME" ]]; then
    ok "~/.roll/ exists  ~/.roll/ 已存在"
  else
    err "~/.roll/ not found — run 'roll setup'  ~/.roll/ 不存在 — 请运行 'roll setup'"
    return
  fi

  echo ""
  echo -e "${BOLD}Global conventions:  全局约定${NC}"
  for f in AGENTS.md CLAUDE.md GEMINI.md .cursor-rules; do
    if [[ -f "$ROLL_GLOBAL/$f" ]]; then
      echo -e "  ${GREEN}+${NC} $f"
    else
      echo -e "  ${RED}-${NC} $f (missing / 缺失)"
    fi
  done

  echo ""
  echo -e "${BOLD}Global skills:  全局技能${NC}"
  if [[ -d "$ROLL_HOME/skills" ]]; then
    local count
    count=$(find "$ROLL_HOME/skills" -maxdepth 1 -type d | wc -l | tr -d ' ')
    count=$((count - 1))
    echo -e "  ${GREEN}+${NC} ~/.roll/skills ($count skills installed / 已安装 $count 个技能)"
  else
    echo -e "  ${RED}-${NC} ~/.roll/skills (missing / 缺失)"
  fi

  echo ""
  echo -e "${BOLD}Sync targets:  同步目标${NC}"

  while IFS= read -r _entry; do
    local _ai_d _cfg _src _tool_name
    _ai_d="$(_ai_dir "$_entry")"
    _cfg="$(_ai_config "$_entry")"
    _src="$(_ai_src "$_entry")"
    _tool_name="$(ai_tool_name "$_ai_d")"
    check_sync_status "$_tool_name" "$ROLL_GLOBAL/$_src" "$_ai_d/$_cfg"
  done < <(_get_ai_tools)

  echo ""
  echo -e "${BOLD}Skill symlinks:  技能软链接${NC}"
  local total_skills=0
  local wk_skills_real
  if [[ -d "$ROLL_HOME/skills" ]]; then
    # Count only wk-* skill dirs to match the linked_count scope below
    total_skills=$(find "$ROLL_HOME/skills" -maxdepth 1 -mindepth 1 -type d -name "wk-*" | wc -l | tr -d ' ')
    wk_skills_real="$(canonical_dir "$ROLL_HOME/skills" 2>/dev/null || true)"
  fi
  while IFS= read -r _entry; do
    local ai_dir
    ai_dir="$(_ai_dir "$_entry")"
    [[ -d "$ai_dir" ]] || continue
    local name name_lower
    name="$(ai_tool_name "$ai_dir")"
    name="$(echo "$name" | tr '[:lower:]' '[:upper:]' | cut -c1)$(echo "$name" | cut -c2-)"
    name_lower="$(lower_name "$name")"
    local skills_dir="$ai_dir/skills"
    if [[ -d "$skills_dir" ]]; then
      if [[ -L "$skills_dir" ]]; then
        local skills_target skills_real
        skills_target="$(readlink "$skills_dir")"
        skills_real="$(canonical_dir "$skills_dir" 2>/dev/null || true)"
        local skills_display="${skills_dir/#$HOME/~}"
        if [[ -n "$skills_real" && "$skills_real" == "$wk_skills_real" ]]; then
          echo -e "  ${GREEN}=${NC} $name: $skills_display -> ~/.roll/skills (mounted / 已挂载)"
        else
          echo -e "  ${YELLOW}~${NC} $name: $skills_display -> ${skills_target/#$HOME/~} (symlinked dir)"
        fi
        continue
      fi

      local linked_count skills_display
      skills_display="${skills_dir/#$HOME/~}"
      linked_count=$(find "$skills_dir" -maxdepth 1 -mindepth 1 -type l -name "wk-*" 2>/dev/null | wc -l | tr -d ' ')
      if [[ "$linked_count" -eq "$total_skills" ]] && [[ "$total_skills" -gt 0 ]]; then
        echo -e "  ${GREEN}=${NC} $name: $skills_display ($linked_count/$total_skills skills linked)"
      elif [[ "$linked_count" -gt 0 ]]; then
        echo -e "  ${YELLOW}~${NC} $name: $skills_display ($linked_count/$total_skills skills linked)"
      else
        echo -e "  ${RED}-${NC} $name: $skills_display (0 wk skills linked / 0 个 wk 技能已链接)"
      fi
    else
      echo -e "  ${RED}-${NC} $name: ${skills_dir/#$HOME/~} (not found / 未找到)"
    fi
  done < <(_get_ai_tools)

  echo ""
  echo -e "${BOLD}Git hook:  Git Hook${NC}"
  local hook_dst="$HOME/.config/git/hooks/prepare-commit-msg"
  local hooks_path
  hooks_path=$(git config --global core.hooksPath 2>/dev/null || true)
  if [[ -f "$hook_dst" ]] && [[ "$hooks_path" == "$HOME/.config/git/hooks" ]]; then
    echo -e "  ${GREEN}+${NC} prepare-commit-msg (global, AI client auto-detect / 全局，自动检测 AI 客户端)"
  elif [[ -f "$hook_dst" ]]; then
    echo -e "  ${YELLOW}~${NC} prepare-commit-msg exists but core.hooksPath not set  prepare-commit-msg 已存在，但 core.hooksPath 未设置"
    echo -e "      run: roll hook install  运行: roll hook install"
  else
    echo -e "  ${RED}-${NC} not installed (optional) — run 'roll hook install'  未安装（可选）— 运行 'roll hook install'"
  fi

  echo ""
  echo -e "${BOLD}Templates:  模板${NC}"
  for tpl in fullstack frontend-only backend-service cli; do
    if [[ -d "$ROLL_TEMPLATES/$tpl" ]]; then
      local count
      count=$(find "$ROLL_TEMPLATES/$tpl" -type f | wc -l | tr -d ' ')
      echo -e "  ${GREEN}+${NC} $tpl ($count files)"
    else
      echo -e "  ${RED}-${NC} $tpl (missing / 缺失)"
    fi
  done
}

check_sync_status() {
  local name="$1"
  local src="$2"
  local dst="$3"

  local display="${dst/#$HOME/~}"
  local dst_dir
  dst_dir="$(dirname "$dst")"
  local wk_file="$dst_dir/wk.md"

  # Sync writes content to {dir}/wk.md and appends @wk.md to the main config.
  # So "in sync" means: wk.md exists + matches source + main config contains @wk.md.
  if [[ ! -f "$dst" ]]; then
    echo -e "  ${RED}-${NC} $name: $display (not synced / 未同步)"
  elif [[ ! -f "$wk_file" ]]; then
    echo -e "  ${YELLOW}~${NC} $name: $display (out of sync — wk.md missing / wk.md 缺失)"
  elif ! diff -q "$src" "$wk_file" &>/dev/null 2>&1; then
    echo -e "  ${YELLOW}~${NC} $name: $display (out of sync — wk.md outdated / wk.md 已过期)"
  elif ! grep -qF "@wk.md" "$dst" 2>/dev/null; then
    echo -e "  ${YELLOW}~${NC} $name: $display (out of sync — @wk.md not in config / 未包含 @wk.md)"
  else
    echo -e "  ${GREEN}=${NC} $name: $display (in sync / 已同步)"
  fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════════════════════
usage() {
  echo -e "${BOLD}Roll${NC} v${VERSION} — AI Agent Convention Manager"
  echo -e "  AI 编码惯例管理器"
  echo ""
  echo "Usage: roll <command> [options]"
  echo "用法:  roll <command> [options]"
  echo ""
  echo "Commands:"
  echo "  setup                  Initialize ~/.roll/ + install skills          初始化 ~/.roll/ + 安装技能"
  echo "  sync [scope] [-f]      Distribute to AI tool config paths              分发约定到各 AI 工具配置路径"
  echo "  init [type]            Initialize or refresh project conventions (cwd) 初始化或刷新项目约定（当前目录）"
  echo "  hook [install|remove] Manage global git hook (opt-in)                管理全局 git hook（可选安装）"
  echo "  reset                  Reset ~/.roll/ from repo, then force-sync     从仓库重置 ~/.roll/，再强制同步"
  echo "  status                 Show current state                              显示当前状态"
  echo ""
  echo "Sync scopes: conventions (default) | skills | all"
  echo "同步范围:    conventions（默认）| skills | all"
  echo ""
  echo "Init types:  fullstack | frontend-only | backend-service | cli | auto"
  echo "初始化类型:  fullstack | frontend-only | backend-service | cli | auto"
  echo ""
  echo "Init tools:  claude,gemini,cursor,all"
  echo "初始化工具:  claude,gemini,cursor,all"
  echo ""
  echo "Examples / 示例:"
  echo "  roll setup                    # First-time setup (non-invasive)         首次安装（非破坏性）"
  echo "  roll sync conventions         # Opt-in: add WK conventions via @include  可选：通过 @include 添加约定"
  echo "  roll sync skills -f           # Rebuild skill symlinks                   重建技能软链接"
  echo "  roll hook install            # Opt-in: global git hook                  可选：全局 git hook"
  echo "  roll init fullstack           # New project (cwd)                        新项目（当前目录）"
  echo "  roll init                     # Refresh existing project (cwd)           刷新已有项目（当前目录）"
}

main() {
  local cmd="${1:-}"
  shift || true

  case "$cmd" in
    setup)         cmd_setup "$@" ;;
    sync)          cmd_sync "$@" ;;
    init)          cmd_init "$@" ;;
    hook)         cmd_hook "$@" ;;
    reset)         cmd_reset "$@" ;;
    status)        cmd_status "$@" ;;
    version|--version|-v) echo "roll v${VERSION}" ;;
    help|--help|-h|"") usage ;;
    *)
      err "Unknown command: $cmd  未知命令: $cmd"
      echo ""
      usage
      exit 1
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
