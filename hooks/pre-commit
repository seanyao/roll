#!/usr/bin/env bash
set -euo pipefail

PROOF="$(git rev-parse --show-toplevel)/.roll/last-test-pass"

_fail() {
  echo "✗ Commit blocked: $1" >&2
  echo "✗ 提交被拒绝：$2" >&2
  echo "Run: roll test   (affected by default; writes the test-pass proof. Full 'npm test' is pre-push only — it won't finish inside the 60s gate.)" >&2
  exit 1
}

# Docs-only exemption: narrative documentation can't break code, so it needn't
# carry a fresh test proof. If EVERY staged path is narrative docs, skip the
# TCR gate entirely. A single non-doc file in the same commit re-arms the full
# check — you can't smuggle code in under a docs commit.
#
# Narrative docs = root-level *.md (README, CHANGELOG, AGENTS…), docs/, guide/.
# Deliberately NOT exempt: skills/**/*.md (prompt contracts with contract
# tests), lib/, bin/, tests/, and any other nested path — those are behavior.
_docs_only() {
  local f had=0
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    had=1
    case "$f" in
      docs/*|guide/*) ;;   # nested narrative docs — exempt
      */*) return 1 ;;     # any other nested path = code/contract
      *.md) ;;             # root-level markdown — exempt
      *) return 1 ;;       # root-level non-markdown (package.json…) = code
    esac
  done < <(git diff --cached --name-only)
  [ "$had" -eq 1 ]         # no staged files at all → not a docs-only commit
}

if _docs_only; then
  exit 0
fi

if [ ! -f "$PROOF" ]; then
  _fail "tests not verified on current code." "当前代码未经测试验证。"
fi

TS=$(grep -o '"ts":[0-9]*' "$PROOF" | grep -o '[0-9]*' || true)
TREE=$(grep -o '"tree":"[^"]*"' "$PROOF" | sed 's/"tree":"//;s/"//' || true)

if [ -z "$TS" ] || [ -z "$TREE" ]; then
  _fail "proof-of-pass record is malformed." "测试证明文件格式错误。"
fi

NOW=$(date +%s)
ELAPSED=$(( NOW - TS ))
if [ "$ELAPSED" -gt 60 ]; then
  _fail "last test run was ${ELAPSED}s ago (limit: 60s)." \
        "上次测试已过 ${ELAPSED} 秒（限制：60 秒）。"
fi

CURRENT_TREE=$(git write-tree)
if [ "$TREE" != "$CURRENT_TREE" ]; then
  _fail "code changed since last test run." "测试后代码已改动。"
fi
