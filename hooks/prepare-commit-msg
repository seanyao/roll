#!/bin/sh
# Append Co-Authored-By trailer to commits made by AI coding agents.
# Detection order: process tree (innermost wins) → env vars → git config fallback

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=${2:-}

# Skip merge and squash commits
case "$COMMIT_SOURCE" in
  merge|squash) exit 0 ;;
esac

head -1 "$COMMIT_MSG_FILE" | grep -qE "^Merge " && exit 0

# ─── Detect AI client ────────────────────────────────────────────────────────
detect_ai_client() {
  pid=$$
  depth=0
  while [ "$pid" -gt 1 ] && [ "$depth" -lt 15 ]; do
    cmd=$(ps -p "$pid" -o comm= 2>/dev/null | tr '[:upper:]' '[:lower:]')
    case "$cmd" in
      *claude*)   echo "claude";   return ;;
      *kimi*)     echo "kimi";     return ;;
      *gemini*)   echo "gemini";   return ;;
      *codex*)    echo "codex";    return ;;
      *cursor*)   echo "cursor";   return ;;
      *deepseek*) echo "deepseek"; return ;;
    esac
    ppid=$(ps -p "$pid" -o ppid= 2>/dev/null | tr -d ' ')
    [ "$ppid" = "$pid" ] && break
    pid=$ppid
    depth=$((depth + 1))
  done

  [ -n "$CLAUDECODE" ]       && echo "claude"   && return
  [ -n "$KIMI_CLI" ]         && echo "kimi"     && return
  [ -n "$GEMINI_CLI_TOOL" ]  && echo "gemini"   && return
  [ -n "$CODEX_CLI" ]        && echo "codex"    && return
  [ -n "$CURSOR_TRACE" ]     && echo "cursor"   && return
  [ -n "$DEEPSEEK_CLI" ]     && echo "deepseek" && return

  git config --get commit.aiClient 2>/dev/null && return
  echo ""
}

# ─── Map client → Co-Authored-By trailer ─────────────────────────────────────
# Override model version via: git config --global commit.aiModel "Claude Opus 4.7"
client_coauthor() {
  local model
  model=$(git config --get commit.aiModel 2>/dev/null)
  case "$1" in
    claude)   echo "Co-Authored-By: ${model:-Claude Sonnet 4.6} <noreply@anthropic.com>" ;;
    kimi)     echo "Co-Authored-By: ${model:-Moonshot Kimi 2.6} <noreply@moonshot.ai>" ;;
    gemini)   echo "Co-Authored-By: ${model:-Google Gemini 3.0} <noreply@google.com>" ;;
    codex)    echo "Co-Authored-By: ${model:-OpenAI Codex 5.4} <noreply@openai.com>" ;;
    cursor)   echo "Co-Authored-By: ${model:-Cursor Agent} <noreply@cursor.com>" ;;
    deepseek) echo "Co-Authored-By: ${model:-Deepseek V4 Flash} <noreply@deepseek.com>" ;;
    *)        echo "" ;;
  esac
}

CLIENT=$(detect_ai_client)
[ -z "$CLIENT" ] && exit 0

TRAILER=$(client_coauthor "$CLIENT")
[ -z "$TRAILER" ] && exit 0

# Idempotent: skip if trailer already present (e.g. on --amend)
grep -qF "$TRAILER" "$COMMIT_MSG_FILE" && exit 0

git interpret-trailers --in-place --trailer "$TRAILER" "$COMMIT_MSG_FILE"
