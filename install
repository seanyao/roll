#!/usr/bin/env bash
set -euo pipefail

# Roll curl|bash installer — US-INSTALL-002 (network tarball download)
# Supports ROLL_VERSION env var to pin version.

OS="$(uname -s)"
if [[ "$OS" != "Darwin" && "$OS" != "Linux" ]]; then
  echo "Unsupported OS: $OS. Only Darwin and Linux are supported." >&2
  exit 1
fi

# Preflight: bash version
if [[ "${BASH_VERSINFO[0]}" -lt 3 ]] || { [[ "${BASH_VERSINFO[0]}" -eq 3 ]] && [[ "${BASH_VERSINFO[1]}" -lt 2 ]]; }; then
  echo "bash >= 3.2 is required (found ${BASH_VERSINFO[0]}.${BASH_VERSINFO[1]})." >&2
  exit 1
fi

# Preflight: python3
if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required but not found." >&2
  if [[ "$OS" == "Darwin" ]]; then
    echo "Install with: brew install python3" >&2
  else
    echo "Install with: sudo apt-get install python3 (Debian/Ubuntu) or sudo dnf install python3 (Fedora)" >&2
  fi
  exit 1
fi

# Preflight: curl
if ! command -v curl >/dev/null 2>&1; then
  echo "curl is required but not found." >&2
  if [[ "$OS" == "Darwin" ]]; then
    echo "Install with: brew install curl" >&2
  else
    echo "Install with: sudo apt-get install curl (Debian/Ubuntu) or sudo dnf install curl (Fedora)" >&2
  fi
  exit 1
fi

# Preflight: tar
if ! command -v tar >/dev/null 2>&1; then
  echo "tar is required but not found." >&2
  if [[ "$OS" == "Darwin" ]]; then
    echo "Install with: brew install gnu-tar (or use system tar)" >&2
  else
    echo "Install with: sudo apt-get install tar (usually pre-installed)" >&2
  fi
  exit 1
fi

# Resolve target version tag from GitHub releases or env override
_resolve_version() {
  if [[ -n "${ROLL_VERSION:-}" ]]; then
    echo "$ROLL_VERSION"
    return 0
  fi

  local latest
  latest=$(curl -fsSL \
    -H "Accept: application/vnd.github+json" \
    "https://api.github.com/repos/seanyao/roll/releases/latest" \
    | grep '"tag_name"' | sed 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' 2>/dev/null || true)

  if [[ -z "$latest" ]]; then
    echo "Failed to resolve latest version from GitHub." >&2
    echo "You can pin a version with ROLL_VERSION=vX.Y.Z" >&2
    exit 1
  fi

  echo "$latest"
}

# Download release tarball and atomically install to data dir
_download_and_install() {
  local tag="$1"
  local url="https://github.com/seanyao/roll/archive/refs/tags/${tag}.tar.gz"
  local tmp_dir
  tmp_dir="$(mktemp -d)"

  echo "[roll] Downloading roll $tag ..."
  if ! curl -fsSL "$url" -o "${tmp_dir}/roll.tar.gz"; then
    rm -rf "$tmp_dir"
    echo "Failed to download $url" >&2
    echo "Check your network connection or pin a version with ROLL_VERSION=vX.Y.Z" >&2
    exit 1
  fi

  echo "[roll] Extracting ..."
  mkdir -p "${tmp_dir}/extract"
  if ! tar -xzf "${tmp_dir}/roll.tar.gz" --strip-components=1 -C "${tmp_dir}/extract"; then
    rm -rf "$tmp_dir"
    echo "Failed to extract tarball." >&2
    exit 1
  fi

  # Atomic install: swap in the newly extracted directory
  rm -rf "$DATA_DIR"
  mkdir -p "$(dirname "$DATA_DIR")"
  mv "${tmp_dir}/extract" "$DATA_DIR"
  rm -rf "$tmp_dir"

  chmod +x "$DATA_DIR/bin/roll"
}

# Installation paths
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/roll"
BIN_DIR="$HOME/.local/bin"
BIN_LINK="$BIN_DIR/roll"

# Resolve version
TAG=$(_resolve_version)
echo "[roll] Installing roll $TAG"

# Download and extract
_download_and_install "$TAG"

# Symlink into PATH
mkdir -p "$BIN_DIR"
ln -sf "$DATA_DIR/bin/roll" "$BIN_LINK"
echo "[roll] Linked: $BIN_LINK -> $DATA_DIR/bin/roll"

# Write install method marker
echo "curl" > "$DATA_DIR/.install-method"

# Ensure ~/.local/bin is in PATH (idempotent)
if ! echo "$PATH" | grep -q "$BIN_DIR"; then
  SHELL_RC=""
  case "${SHELL:-}" in
    */zsh)  SHELL_RC="$HOME/.zshrc" ;;
    */bash) SHELL_RC="$HOME/.bashrc" ;;
  esac

  if [[ -n "$SHELL_RC" ]]; then
    EXPORT_LINE='export PATH="$HOME/.local/bin:$PATH"'
    if ! grep -qF "$EXPORT_LINE" "$SHELL_RC" 2>/dev/null; then
      echo "" >> "$SHELL_RC"
      echo "# Added by roll install" >> "$SHELL_RC"
      echo "$EXPORT_LINE" >> "$SHELL_RC"
      echo "[roll] Added PATH entry to $SHELL_RC"
    fi
  fi

  # Also export for the remainder of this session
  export PATH="$BIN_DIR:$PATH"
fi

# Run first-time setup
echo ""
roll setup
