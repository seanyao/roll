{
  "name": "@seanyao/roll",
  "version": "4.714.2",
  "description": "Roll — Roll out features with AI agents",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "test": "bash scripts/test-ts.sh",
    "lint:story-ids": "node scripts/lint-story-ids.mjs",
    "lint:role-taxonomy": "node scripts/audit-role-taxonomy.mjs",
    "test:e2e": "pnpm -r build && pnpm --filter @roll/cli exec vitest run test/critical-flows.e2e.test.ts",
    "test:cov": "pnpm -r exec vitest run --coverage.enabled --coverage.provider=v8 --coverage.include='src/**' --coverage.reporter=text-summary --coverage.reporter=text",
    "bundle": "node scripts/bundle.mjs",
    "postinstall": "node scripts/postinstall-roll-capture.mjs",
    "prepack": "pnpm -r build && pnpm bundle"
  },
  "keywords": [
    "ai",
    "agent",
    "development-workflow",
    "skills",
    "agent-first"
  ],
  "homepage": "https://github.com/seanyao/roll",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seanyao/roll.git"
  },
  "bin": {
    "roll": "dist/roll.mjs"
  },
  "license": "MIT",
  "author": "Sean Yao <sean.dlut@gmail.com>",
  "files": [
    "dist/",
    "conventions/",
    "docs/",
    "guide/",
    "lib/",
    "scripts/postinstall-roll-capture.mjs",
    "skills/",
    "template/",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "4.1.8",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
