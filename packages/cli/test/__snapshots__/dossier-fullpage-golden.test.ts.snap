x 8px 9px;"><a class="bl-row" data-state="wip" data-text="us-obs-1 observability first card" href="loop-observability/US-OBS-1/index.html" style="display:grid;grid-template-columns:62px 150px 1fr 110px minmax(150px,auto);align-items:center;gap:12px;padding:8px 10px;border-radius:8px;cursor:pointer;text-decoration:none;"><span style="font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.05em;text-transform:uppercase;font-weight:600;padding:2px 7px;border-radius:5px;border:1px solid #2d54e844;color:#2d54e8;text-align:center;">US</span><span style="font-family:'IBM Plex Mono',monospace;font-size:12.5px;color:#2d54e8;font-weight:600;overflow:hidden;text-overflow:ellipsis;">US-OBS-1</span><span style="font-size:13.5px;color:#525c6e;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">Observability first card</span><span style="display:inline-flex;gap:3px;"><span title="definition" style="width:14px;height:5px;border-radius:3px;background:#178a52;"></span><span title="design" style="width:14px;height:5px;border-radius:3px;background:#e4e8ef;"></span><span title="execution" style="width:14px;height:5px;border-radius:3px;background:#e4e8ef;"></span><span title="delivery" style="width:14px;height:5px;border-radius:3px;background:#e4e8ef;"></span><span title="retrospective" style="width:14px;height:5px;border-radius:3px;background:#e4e8ef;"></span></span><span style="display:flex;align-items:center;gap:7px;justify-content:flex-end;font-family:'IBM Plex Mono',monospace;font-size:11px;"><span style="width:7px;height:7px;border-radius:50%;background:#2d54e8;flex:none;"></span><span style="color:#2d54e8;font-weight:600;"><span class="lang-en">WIP</span><span class="lang-zh">进行中</span></span></span></a></div></details><div style="display:flex;align-items:baseline;gap:12px;margin:24px 0 12px;"><span style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:#525c6e;font-weight:600;"><span class="lang-en">Settled on main</span><span class="lang-zh">已落定</span></span><span style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#178a52;font-weight:600;">0</span><span style="flex:1;height:1px;background:#dfe4ec;"></span></div></div><div id="tab-loop" style="display:none;"><div style="padding:30px 0 4px;"><div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:#2d54e8;font-weight:600;"><span class="lang-en">The engine says it runs — here is the tape</span><span class="lang-zh">引擎说在跑——这是轨迹带</span></div><h1 style="margin:10px 0 0;font-size:28px;line-height:1.1;font-weight:700;letter-spacing:-.02em;color:#161b26;"><span class="lang-en">Loop & Cycles</span><span class="lang-zh">循环与周期</span></h1><p style="margin:10px 0 0;max-width:660px;font-size:14.5px;line-height:1.55;color:#525c6e;"><span class="lang-en">Every cycle, complete and replayable. Failures are first-class — never swallowed.</span><span class="lang-zh">每一个 cycle 完整、可回溯。失败是一等公民——绝不吞。</span></p></div><div style="display:flex;align-items:baseline;gap:12px;margin:24px 0 12px;flex-wrap:wrap;"><span style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:#525c6e;font-weight:600;"><span class="lang-en">Loops on this repo</span><span class="lang-zh">本仓 Loops</span></span><span style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:#9aa3b2;"><span class="lang-en">backlog · PR · dream · go sessions</span><span class="lang-zh">backlog · PR · dream · go 会话</span></span><span style="flex:1;height:1px;background:#dfe4ec;min-width:16px;"></span><span style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:#8a93a3;white-space:nowrap;">0/1 <span class="lang-en">running</span><span class="lang-zh">运行中</span></span></div><section style="border:1px solid #e0e5ee;border-radius:14px;background:#fff;overflow:hidden;margin:0 0 8px;box-shadow:0 1px 2px rgba(17,26,69,.05);"><div data-now-section="heartbeat-head" style="display:grid;grid-template-columns:1.6fr .8fr .7fr 1fr 1fr;align-items:center;gap:14px;padding:9px 18px;border-top:1px solid #eef1f5;background:#fafbfe;"><span style="font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.09em;text-transform:uppercase;color:#9aa3b2;">Lane</span><span style="font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.09em;text-transform:uppercase;color:#9aa3b2;"><span class="lang-en">mode</span><span class="lang-zh">模式</span></span><span style="font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.09em;text-transform:uppercase;color:#9aa3b2;"><span class="lang-en">every</span><span class="lang-zh">周期</span></span><span style="font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.09em;text-transform:uppercase;color:#9aa3b2;"><span class="lang-en">last</span><span class="lang-zh">上次</span></span><span style="font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.09em;text-transform:uppercase;color:#9aa3b2;"><span class="lang-en">next</span><span class="lang-zh">下次</span></span></div><div style="display:grid;grid-template-columns:1.6fr .8fr .7fr 1fr 1fr;align-items:center;gap:14px;padding:13px 18px;border-top:1px solid #f4f6f9;"><div style="display:flex;align-items:center;gap:11px;min-width:0;"><span style="width:9px;height:9px;border-radius:50%;background:#c2402a;flex:none;"></span><div style="min-width:0;"><div style="font-size:13.5px;font-weight:600;color:#161b26;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">backlog loop</div><div style="font-family:'IBM Plex Mono',monospace;font-size:10.5px;color:#c2402a;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><span class="lang-en">zombie</span><span class="lang-zh">僵尸</span></div></div></div><div style="font-size:12.5px;color:#3a4252;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">backlog</div><div style="font-size:12.5px;color:#3a4252;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">—</div><div style="font-family:'IBM Plex Mono',monospace;font-size:12.5px;color:#3a4252;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">06-20 11:00Z</div><div class="hb-next" data-next="" style="font-family:'IBM Plex Mono',monospace;font-size:12.5px;color:#3a4252;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">—</div></div></section><div style="display:flex;align-items:center;gap:12px;margin:24px 0 12px;flex-wrap:wrap;"><span style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:#525c6e;font-weight:600;white-space:nowrap;"><span class="lang-en">Hooks · this repo</span><span class="lang-zh">钩子 · 本仓</span></span><span style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:#9aa3b2;"><span class="lang-en">git hooks wired into this checkout</span><span class="lang-zh">本检出已配置的 git 钩子</span></span><span style="flex:1;height:1px;background:#dfe4ec;min-width:16px;"></span><span style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:#8a93a3;white-space:nowrap;">0 <span class="lang-en">git hooks</span><span class="lang-zh">git 钩子</span> · .git/hooks</span></div><section data-hooks="this-repo" style="border:1px solid #e0e5ee;border-radius:12px;background:#fff;overflow:hidden;margin:0 0 8px;box-shadow:0 1px 2px rgba(17,26,69,.05);"><div style="padding:14px 18px;font-size:12.5px;color:#9aa3b2;font-style:italic;"><span class="lang-en">no configured git hooks in this checkout</span><span class="lang-zh">本检出没有已配置的 git 钩子</span></div></section><div style="display:flex;align-items:center;gap:12px;margin:24px 0 12px;flex-wrap:wrap;"><span style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:#525c6e;font-weight:600;"><span class="lang-en">Cycle ledger</span><span class="lang-zh">周期账本</span></span><span style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:#9aa3b2;"><span class="lang-en">what it actually did while you were away</span><span class="lang-zh">你不在的时候它到底干了什么</span></span><span style="flex:1;height:1px;background:#dfe4ec;min-width:16px;"></span><div style="display:flex;border:1px solid #dfe4ec;border-radius:999px;overflow:hidden;background:#fff;"><button type="button" class="cy-range on" data-range="recent" style="appearance:none;border:0;background:transparent;font-family:'IBM Plex Mono',monospace;font-size:11px;padding:6px 13px;cursor:pointer;color:#525c6e;"><span class="lang-en">Recent</span><span class="lang-zh">近期</span></button><button type="button" class="cy-range" data-range="1" style="appearance:none;border:0;background:transparent;font-family:'IBM Plex Mono',monospace;font-size:11px;padding:6px 13px;cursor:pointer;color:#525c6e;"><span class="lang-en">Today</span><span class="lang-zh">今天</span></button><button type="button" class="cy-range" data-range="3" style="appearance:none;border:0;background:transparent;font-family:'IBM Plex Mono',monospace;font-size:11px;padding:6px 13px;cursor:pointer;color:#525c6e;"><span class="lang-en">3 days</span><span class="lang-zh">三天</span></button><button type="button" class="cy-range" data-range="7" style="appearance:none;border:0;background:transparent;font-family:'IBM Plex Mono',monospace;font-size:11px;padding:6px 13px;cursor:pointer;color:#525c6e;"><span class="lang-en">7 days</span><span class="lang-zh">七天</span></button><button type="button" class="cy-range" data-range="all" style="appearance:none;border:0;background:transparent;font-family:'IBM Plex Mono',monospace;font-size:11px;padding:6px 13px;cursor:pointer;color:#525c6e;"><span class="lang-en">All</span><span class="lang-zh">全部</span></button></div><span style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:#8a93a3;white-space:nowrap;"><span id="cy-count">—</span> <span class="lang-en">shown</span><span class="lang-zh">显示</span> <span style="color:#9aa3b2;">·</span> <b id="cy-failed" style="color:#d23b3b;font-weight:600;">—</b> <span class="lang-en">failed (all)</span><span class="lang-zh">失败（全部）</span></span></div><section id="cy-ledger" style="border:1px solid #e0e5ee;border-radius:14px;background:#fff;overflow:hidden;box-shadow:0 1px 2px rgba(17,26,69,.05);"><div style="padding:16px 18px;font-size:12.5px;color:#9aa3b2;font-style:italic;"><span class="lang-en">no cycles recorded yet</span><span class="lang-zh">尚无周期记录</span></div></section></div><div id="tab-release" style="display:none;"><div style="padding:30px 0 4px;"><div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:#2d54e8;font-weight:600;"><span class="lang-en">It says it will ship — the gate decides</span><span class="lang-zh">说要发——闸门说了算</span></div><h1 style="margin:10px 0 0;font-size:28px;line-height:1.1;font-weight:700;letter-spacing:-.02em;color:#161b26;"><span class="lang-en">Release</span><span class="lang-zh">发版</span></h1><p style="margin:10px 0 0;max-width:660px;font-size:14.5px;line-height:1.55;color:#525c6e;"><span class="lang-en">Why can't it ship? Read it, don't guess it: six reconciled dimensions, every drift with an address.</span><span class="lang-zh">为什么发不了版？读出来，不用猜：六个对账维度，每处漂移都有地址。</span></p></div><section style="border:1px solid #e0e5ee;border-radius:12px;background:#fff;overflow:hidden;margin:20px 0 8px;box-shadow:0 1px 2px rgba(17,26,69,.05);"><div style="display:flex;flex-wrap:wrap;align-items:center;gap:30px;padding:16px 20px;"><div><div style="font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:#9aa3b2;"><span class="lang-en">release</span><span class="lang-zh">发版</span></div><div style="font-family:'IBM Plex Mono',monospace;font-size:24px;font-weight:600;color:#161b26;margin-top:3px;">—</div></div><div><div style="font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:#9aa3b2;"><span class="lang-en">verdict</span><span class="lang-zh">判定</span></div><div style="margin-top:6px;"><span style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.05em;text-transform:uppercase;font-weight:600;padding:3px 10px;border-radius:999px;border:1px solid #727c8e55;color:#727c8e;">unknown</span></div></div><div><div style="font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:#9aa3b2;"><span class="lang-en">gate</span><span class="lang-zh">闸门</span></div><div style="font-family:'IBM Plex Mono',monospace;font-size:13px;color:#3a4252;margin-top:8px;white-space:nowrap;">f:0 w:0 ?:0</div></div><div><div style="font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:#9aa3b2;"><span class="lang-en">cut</span><span class="lang-zh">切版</span></div><div style="font-family:'IBM Plex Mono',monospace;font-size:13px;color:#3a4252;margin-top:8px;white-space:nowrap;">—</div></div><div><div style="font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:#9aa3b2;"><span class="lang-en">previous</span><span class="lang-zh">上一版</span></div><div style="font-family:'IBM Plex Mono',monospace;font-size:13px;color:#3a4252;margin-top:8px;white-space:nowrap;">—</div></div><span style="flex:1;"></span><div style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#8a93a3;white-space:nowrap;"><b style="color:#178a52;font-weight:600;">0</b> <span class="lang-en">merged</span><span class="lang-zh">已合</span> · <b style="color:#c77d12;font-weight:600;">0</b> <span class="lang-en">pending</span><span class="lang-zh">待交付</span></div></div><div style="padding:0 20px 16px;"><div style="display:flex;height:11px;border-radius:999px;overflow:hidden;border:1px solid #e4e8ef;"><span style="width:100%;background:#178a52;"></span><span style="flex:1;background:#eef1f5;"></span></div></div></sec