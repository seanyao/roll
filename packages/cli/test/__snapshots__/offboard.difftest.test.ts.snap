exports[`diff-test: roll offboard == bash oracle > no changeset → exit 1 (en) 1`] = `
{
  "status": 1,
  "stderr": "[roll] No onboard changeset found at .roll/onboard-changeset.yaml
[roll] 未找到 onboard 变更清单 .roll/onboard-changeset.yaml

  Manual offboard — remove these by hand if they came from Roll:
    rm -rf .roll/                  # all process artefacts
    rm -f AGENTS.md CLAUDE.md      # only if they were generated by roll init
    Edit .gitignore to remove any '.roll/' entry
",
  "stdout": "",
}
`;

