exports[`diff-test: roll offboard == bash oracle > with-plists --confirm inside loop cycle → FIX-125 refuse 1`] = `
{
  "status": 1,
  "stderr": "[roll] Refusing to unload launchd plists from inside a loop cycle (FIX-125).
  Run 'roll offboard --confirm' from a terminal outside the cycle,
  or pause the loop first: 'roll loop pause'.
",
  "stdout": "
  Offboard plan for <PROJ>

  Files to remove:
    rm   AGENTS.md

  launchd plists to unload:
    unload com.roll.test.loop.plist

",
}
`;

