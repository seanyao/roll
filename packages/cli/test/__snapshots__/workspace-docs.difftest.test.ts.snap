exports[`US-WS-021 Workspace-first documentation contract > freezes Workspace-aware command help in one visible language per locale 1`] = `
{
  "en": {
    "agent": "Usage: roll agent [--workspace <id|path>|migrate [--dry-run]|list|readiness|cast]
  Inspect machine Agent Scope, readiness and role casting; --workspace resolves one read-only Workspace casting trace.

Workspace selector alias: --ws <id|path> (canonical: --workspace <id|path>)
",
    "backlog": "Usage: roll backlog [show <story-id>] [--workspace <id|path>] [--interactive|--no-input] [--all]
       roll backlog <block|defer|unblock|promote|claim|lint|unstick|sync> ... [--workspace <id|path>]
  Reads may explicitly enable/disable Workspace clarification; --all is read-only and mutations are rejected.

Workspace selector alias: --ws <id|path> (canonical: --workspace <id|path>)
",
    "delivery": "Usage: roll delivery <list|show|reconcile> [options]
  \`list [--workspace <id|path> | --all] [--interactive|--no-input] [--json]\`
  \`show <story-id> [--workspace <id|path>] [--interactive|--no-input] [--json]\`
  \`reconcile [<story-id>] --workspace <id|path> [--dry-run] [--json]\`
  Interaction capability is independent from --json; prompts use the controlling TTY, never stdout. Delivery is an Issue fact view; --all is read-only and reconciliation never reads backlog Markdown as completion truth.

Workspace selector alias: --ws <id|path> (canonical: --workspace <id|path>)
",
    "loop": "Usage: roll loop <subcommand>
The autonomous delivery loop — grouped control / observe / alerts / maintain.

control   on --workspace <id|path> · off [--all] · now · pause --workspace <id|path> · resume --workspace <id|path> · reset · go --workspace <id|path> · goal · recover · fallback
observe   watch · status [--workspace <id|path>|--all] · runs · log · events · signals · eval
alerts    alert list · alert ack · alert resolve · alert log
maintain  gc · fmt · mute · unmute · reconcile --workspace <id|path> · reconcile-pending
internal  test · run-once · story · notify · enforce-tcr · precheck-ci · hotfix-head-context · agent-routes

states    ACTIVE (lanes armed) · DORMANT (backlog drained → loop lane self-unloads, zero idle records) · PAUSED (you stopped it)
wake      a DORMANT loop wakes on any roll command · the daily dream scan · a PR merge

Workspace selector alias: --ws <id|path> (canonical: --workspace <id|path>)
",
    "workspace": "Usage: roll workspace <create|edit|issue|requirement|doctor|migrate|list|show|register|activate|pause|archive> [options]
  \`create <id> --config <file> [--authorization <file>] [--check] [--json]\`
  \`edit <id|path> --config <file> --check [--json]\`
  \`issue init <story-id> --workspace <id> [--check] [--json]\`
  \`requirement add --provider <provider> --ref <ref> --revision <revision> --body-file <file> --story <id> [options]\`
  \`doctor <id> [--json] [--repair <typed-action>] [--path <absolute-path>]\`
  \`migrate --from <repo> --check [--workspace <id>] [--json]\`
  \`migrate --from <repo> --workspace <id> --plan <file> [--rollback] [--json]\`
  \`list [--json] [--all]\`
  \`show <id|path> [--json]\`
  \`register <id> <path> [--json]\`
  \`activate|pause|archive <id|path> [--json]\`
  Create/edit/issue/migrate --check and doctor diagnosis are read-only; migrate apply/rollback, typed doctor repairs and lifecycle mutations require one explicit target; --all is read-only.

Alias: roll ws ... (canonical: roll workspace ...)
Workspace selector alias: --ws <id|path> (canonical: --workspace <id|path>)
",
  },
  "zh": {
    "agent": "用法：roll agent [--workspace <ID|路径>|migrate [--dry-run]|list|readiness|cast]
